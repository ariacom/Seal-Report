@using Seal.Model
@using Seal.Helpers
@{
    WebMainModel model = Model as WebMainModel;
    Repository repository = model.Repository;
}
<script type="text/javascript">
    var menuStyle = "";
</script>
<style>
    /* Bootstrap 5: the Seal Web Interface reveals navbar groups with jQuery .show(),
       which sets inline "display: block" on the navbar-nav <ul>, overriding BS5 flex so
       the <li> icons stack vertically (some li also carry .d-flex / .d-sm-block !important
       utilities, so forcing the <li> display is not enough). Force the shown <ul> back to a
       horizontal flex row; every <li> then becomes a flex item in one row.
       Inlined here so it is always served fresh, immune to the CSS file cache. */
    #bar_top .navbar-nav.navbar-right[style*="display: block"] {
        display: flex !important;
        flex-direction: row;
        align-items: center;
    }
    /* Darker background for the Favorites/Recents section labels (reports menu + AI
       chat dropdown). Inlined here so it overrides the cached sealweb.css regardless
       of file cache. */
    #menu-main li.menu-fav-label,
    .ai-panel-dropdown-label {
        background: #e6e6e6 !important;
        color: #333 !important;
    }
</style>

<nav id="bar_top" class="navbar navbar-expand navbar-dark bg-dark fixed-top" style="transition:top 0.3s;">
    <div class="container-fluid">
        <a id="brand-id" class="navbar-brand d-none d-sm-block" href="#">@repository.Configuration.WebProductName</a>
        <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbar" aria-expanded="false" aria-controls="navbar" aria-label="@repository.TranslateWeb("Toggle navigation")">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div id="navbar" class="collapse navbar-collapse">
            <!-- LEFT: reports menu + contextual breadcrumb; me-auto pushes everything else to the right -->
            <ul class="navbar-nav me-auto align-items-center">
                <li class="nav-item dropdown">
                    <a id="menu-main-button" href="#" class="nav-link p-0" data-bs-toggle="dropdown" title="@repository.TranslateWeb("Reports menu")">
                        <span class="btn btn-sm btn-primary"><span class="fa-solid fa-bars" aria-hidden="true"></span></span>
                    </a>
                    <ul id="menu-main" class="dropdown-menu">
                    </ul>
                </li>
                <li class="nav-item d-flex align-items-center"><span id="nav_cr" class="navbar-text px-2" style="display:none;font-size:10px;text-align:center;"></span></li>
                <li class="nav-item"><a id="nav_button" href="#" class="nav-link"></a></li>
                <li class="nav-item d-flex align-items-center"><span id="nav_badge" class="badge d-none">@repository.TranslateReport("Nav")</span></li>
            </ul>
            <!-- CONTEXT (folder view): refresh / manage folders, then search -->
            <ul class="navbar-nav navbar-right align-items-center">
                <li class="nav-item folderview"><a id="refresh-nav-item" class="nav-link navbar-white" title="@repository.TranslateWeb("Refresh")"><i class="fa-solid fa-arrows-rotate"></i></a></li>
                <li class="nav-item folderview" style="display:none;" title="@repository.TranslateWeb("Manage Folders")"><a id="folders-nav-item" style="font-size:20px" class="nav-link navbar-white"><i class="fa-solid fa-folder-open"></i></a></li>
            </ul>
            <!-- NOTE: no "d-flex" here — it is display:flex !important and would override the
                 jQuery .hide() (inline display:none) used to hide .folderview in report view,
                 leaving the search box visible while a report is executed in the main window. -->
            <form class="folderview navbar-right me-2" style="display:none;">
                <div class="input-group">
                    <input id="search-pattern" type="text" class="form-control form-control-sm" style="width:120px" placeholder="@repository.TranslateWeb("Search")" />
                    <button id="search-nav-item" type="button" class="btn btn-sm btn-success"><span class="fa-solid fa-magnifying-glass"></span></button>
                </div>
            </form>
            <!-- CONTEXT: report tabs (report view) -->
            <ul class="navbar-nav navbar-right align-items-center" role="tablist">
                <li class="nav-item"><a id="report_button" class="nav-link sr_tab reportview" data-bs-toggle="tab" href="#report_div">@repository.TranslateReport("Report")</a></li>
                <li class="nav-item"><a id="information_button" class="nav-link sr_tab reportview" data-bs-toggle="tab" href="#information_div">@repository.TranslateReport("Information")</a></li>
                <li class="nav-item"><a id="message_button" class="nav-link sr_tab reportview" data-bs-toggle="tab" href="#message_div">@repository.TranslateReport("Messages")</a></li>
                <li id="results_menu" class="nav-item dropdown reportview">
                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                        @repository.TranslateReport("Results")
                    </a>
                    <ul class="dropdown-menu">
                        <li><a id="ResultOptions" class="dropdown-item" href="#">@repository.TranslateReport("Options")...</a></li>
                        <li><hr class="dropdown-divider"></li>
                        @foreach (var format in repository.ResultAllowedFormats)
                        {
                            <li><a id="ViewResult" format="@format" class="dropdown-item result_item" href="#">@repository.TranslateReport("View " + Helper.GetEnumDescription(typeof(ReportFormat), format) + " Result")</a></li>
                        }
                    </ul>
                </li>
            </ul>
            <!-- CONTEXT (report view): report actions — after the tabs, ordered restrictions, Execute, reload -->
            <button id="restrictions_button" type="button" class="btn btn-info reportview navbar-right me-2" title="@repository.TranslateReport("Show Restrictions")" data-show-title="@repository.TranslateReport("Show Restrictions")" data-hide-title="@repository.TranslateReport("Hide Restrictions")">
                <span class="fa-solid fa-filter"></span>
            </button>
            <button id="execute_button" class="btn btn-success reportview navbar-right me-2">@repository.TranslateReport("Execute")</button>
            <button id="reload-nav-item" class="btn btn-primary reportview navbar-right me-2" title="@repository.TranslateWeb("Reload and execute")">
                <span class="fa-solid fa-play"></span>
            </button>
            <!-- FAR RIGHT: account / utility cluster (with a divider) -->
            <ul id="navbar-right-menu" class="navbar-nav navbar-right align-items-center">
                <li class="nav-item d-flex align-items-center"><div class="vr mx-2" style="min-height:24px;opacity:.4;"></div></li>
                <li class="nav-item"><a id="profile-nav-item" class="nav-link navbar-white" style="font-size:20px" title="@repository.TranslateWeb("Profile")"><i class="fa-solid fa-user"></i></a></li>
                @if (!string.IsNullOrEmpty(repository.Configuration.WebHelpLink))
                {
                        <li class="nav-item"><a href="@repository.Configuration.WebHelpLink" target="_blank" class="nav-link navbar-white" style="font-size:20px" title="@repository.TranslateWeb("Information")"><i class="fa-solid fa-circle-info"></i></a></li>
                }
                <li class="nav-item"><a id="disconnect-nav-item" class="nav-link navbar-white" style="font-size:20px" title="@repository.TranslateWeb("Disconnect")"><i class="fa-solid fa-right-from-bracket"></i></a></li>
            </ul>
        </div><!--/.nav-collapse -->
    </div><!--/.container-fluid -->
</nav>
