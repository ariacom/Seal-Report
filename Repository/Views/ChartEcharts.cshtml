@using Seal.Model
@using Seal.Helpers
@{
    Report report = Model;
    ReportView view = report.CurrentView;
    ReportView modelView = view.ModelView;
    ReportModel reportModel = modelView.Model;
    ResultPage page = report.CurrentPage;
    if (page == null) { return; }
    var series = page.Series.Where(i => i.Element.EChartsSerie != EChartsSerieDefinition.None).OrderBy(i => i, new ResultSerieComparer());
}

@if (reportModel.HasEChartsSerie && series.Count() > 0 && modelView.GetBoolValue("show_charts"))
{
    <!--Chart ECharts-->
    bool chartOk = false;
    var axisCount = view.GetNumericValue("echarts_xaxis_count");
    string chartId = "cec" + Guid.NewGuid().ToString().Replace("-", "");
    if (modelView.InitPageChart(page))
    {
        page.SetIdentifier(ResultPageIdentifierType.ChartEChartsCanvas, chartId);
        var chartType = reportModel.ExecEChartsChartType;
        var xAxisType = reportModel.ExecChartIsDateTimeAxis ? "time" : (reportModel.ExecChartIsNumericAxis ? "value" : "category");
        var hasSecondary = series.Any(i => i.Element.YAxisType == AxisType.Secondary);
        var xLabels = string.Join(",", axisCount > 0 ? page.ChartXLabels.Take(axisCount) : page.ChartXLabels);
        var height = view.GetValue("echarts_height");
        if (string.IsNullOrEmpty(height)) { height = "400px"; }

        <div id="@chartId" style="page-break-inside:avoid;@Helper.AddIfNotEmpty("width:", view.GetValue("echarts_width"), ";")height:@height;"></div>

        <script>
            $(document).ready(function () {
                var dom = document.getElementById('@chartId');
                var myChart = echarts.init(dom);

                var chartType = '@chartType';
                if (!chartType) chartType = 'line';
                var xAxisType = '@xAxisType';
                var yIsTime = @Helper.ToJS(reportModel.ExecAxisPrimaryYIsDateTime);
                var y2IsTime = @Helper.ToJS(reportModel.ExecAxisSecondaryYIsDateTime);
                var hasSecondary = @Helper.ToJS(hasSecondary);

                var smooth = @view.GetBoolValueJS("echarts_line_smooth");
                var barHorizontal = @view.GetBoolValueJS("echarts_bar_horizontal");
                var barStacked = @view.GetBoolValueJS("echarts_bar_stacked");
                var showLabels = @view.GetBoolValueJS("echarts_show_datalabels");
                var showLegend = @view.GetBoolValueJS("echarts_show_legend");
                var showToolbox = @view.GetBoolValueJS("echarts_show_toolbox");
                var legendOrient = '@view.GetValue("echarts_legend_orientation")';
                var pieRadius = '@view.GetValue("echarts_pie_radius")';
                var pieRoseType = '@view.GetValue("echarts_pie_roseType")';
                var colorList = @Raw(string.IsNullOrEmpty(view.GetValue("echarts_colors")) ? "null" : view.GetValue("echarts_colors"));

                var xLabels = [@Raw(xLabels)];
                var navigations = [@Raw(string.Join(",", page.ChartNavigations))];
                var title = '@Raw(Helper.ToJS(modelView.GetTranslatedMappedLabel(view.GetValue("echarts_title"))))';
                var xTitle = '@Raw(Helper.ToJS(modelView.GetTranslatedMappedLabel(view.GetValue("echarts_xaxis_title"))))';
                var yTitle = '@Raw(Helper.ToJS(modelView.GetTranslatedMappedLabel(view.GetValue("echarts_yaxis_title"))))';
                var y2Title = '@Raw(Helper.ToJS(modelView.GetTranslatedMappedLabel(view.GetValue("echarts_yaxis2_title"))))';
                var primaryYFormat = '@Raw(Helper.ToJS(reportModel.ExecD3PrimaryYAxisFormat))';
                var secondaryYFormat = '@Raw(Helper.ToJS(reportModel.ExecD3SecondaryYAxisFormat))';

                var rawSeries = [
                    @foreach (ResultSerie serie in series)
                    {
                        var yvals = axisCount > 0 ? string.Join(",", serie.ChartYSerieValues.Split(',').Take(axisCount)) : serie.ChartYSerieValues;
                        <text>
                        {
                            name: '@Raw(Helper.ToJS(serie.SerieDisplayName))',
                            y: [@Raw(yvals)],
                            @if (reportModel.ExecChartIsNumericAxis)
                            {
                                var xvals = axisCount > 0 ? string.Join(",", serie.ChartXSerieValues.Split(',').Take(axisCount)) : serie.ChartXSerieValues;
                                <text>x: [@Raw(xvals)],</text>
                            }
                            @if (reportModel.ExecChartIsDateTimeAxis)
                            {
                                var xdates = axisCount > 0 ? string.Join(",", serie.ChartXDateTimeSerieValues.Split(',').Take(axisCount)) : serie.ChartXDateTimeSerieValues;
                                <text>xd: [@Raw(xdates)],</text>
                            }
                            @if (reportModel.ExecAxisPrimaryYIsDateTime)
                            {
                                var ydates = axisCount > 0 ? string.Join(",", serie.ChartYDateSerieValues.Split(',').Take(axisCount)) : serie.ChartYDateSerieValues;
                                <text>yd: [@Raw(ydates)],</text>
                            }
                            mixType: '@serie.EChartsMixedChartType',
                            isArea: @Helper.ToJS(serie.EChartsIsArea),
                            secondary: @Helper.ToJS(serie.Element.YAxisType == AxisType.Secondary)
                        },
                        </text>
                    }
                ];

                function fmt(v, fmtStr, isTime) {
                    if (v === null || v === undefined || v === '') return v;
                    if (!fmtStr) return v;
                    //A date axis carries a d3.timeFormat string (e.g. %m/%d/%Y) and the value is a date (a "yyyy-MM-dd HH:mm:ss" string in the tooltip/label path, a timestamp on the axis); feeding it to d3.format (numeric) mangles it (e.g. 83936880000000%), and the isNaN guard would otherwise drop the date string and leave the raw "00:00:00". Branch on the axis type like the ChartJS view does.
                    try {
                        if (isTime) { var d = new Date(v); return isNaN(d.getTime()) ? v : d3.timeFormat(fmtStr)(d); }
                        if (isNaN(v)) return v;
                        return d3.format(fmtStr)(v).valueFormat();
                    } catch (e) { return v; }
                }
                function fmtY(v, secondary) { return fmt(v, secondary ? secondaryYFormat : primaryYFormat, secondary ? y2IsTime : yIsTime); }

                function pointData(s) {
                    var data = [];
                    for (var k = 0; k < s.y.length; k++) {
                        var yv = (yIsTime && s.yd) ? s.yd[k] : s.y[k];
                        if (xAxisType === 'category') data.push(yv);
                        else if (xAxisType === 'value') data.push([s.x[k], yv]);
                        else data.push([s.xd[k], yv]);
                    }
                    return data;
                }

                var legend = showLegend ? { type: 'scroll', orient: legendOrient, top: title ? 30 : 5 } : null;
                var toolbox = showToolbox ? { feature: { dataZoom: { yAxisIndex: 'none' }, dataView: { readOnly: true }, restore: {}, saveAsImage: {} } } : null;

                var option = {
                    //ECharts defaults to the CJK font "Microsoft YaHei", which renders Latin punctuation (e.g. the thousand separator U+2019) full-width, leaving a big gap after the separator. Force the page's Latin sans-serif stack so numbers format tightly (matching the ChartJS/Plotly charts).
                    textStyle: { fontFamily: "'Helvetica Neue', Helvetica, Arial, sans-serif" },
                    title: title ? { text: title, left: 'center' } : undefined,
                    legend: legend || undefined,
                    toolbox: toolbox || undefined,
                    tooltip: {}
                };
                //Only set a palette when one is provided: assigning color:undefined would wipe ECharts' default palette and draw the series with no color (invisible).
                if (colorList) option.color = colorList;

                if (chartType === 'pie') {
                    if (legend) legend.data = xLabels;
                    option.tooltip = { trigger: 'item', formatter: function (p) { return p.name + '<br/>' + fmtY(p.value) + ' (' + p.percent + '%)'; } };
                    var radius = pieRadius.indexOf(',') >= 0 ? pieRadius.split(',') : pieRadius;
                    option.series = [{
                        type: 'pie',
                        radius: radius,
                        roseType: pieRoseType || undefined,
                        data: xLabels.map(function (l, i) { return { name: l, value: rawSeries[0].y[i] }; }),
                        label: { show: true, formatter: '{b}: {d}%' }
                    }];
                }
                else if (chartType === 'radar') {
                    if (legend) legend.data = rawSeries.map(function (s) { return s.name; });
                    //Radar tooltip defaults to raw unformatted values; build it from the indicators so each axis value goes through fmtY (the primary Y format).
                    option.tooltip = {
                        trigger: 'item',
                        formatter: function (p) {
                            var vals = p.value || [];
                            var rows = xLabels.map(function (l, i) { return l + ': ' + fmtY(vals[i]); }).join('<br/>');
                            return (p.name ? p.name + '<br/>' : '') + rows;
                        }
                    };
                    var indicators = xLabels.map(function (l, i) {
                        var mx = 0;
                        for (var s = 0; s < rawSeries.length; s++) { var v = rawSeries[s].y[i]; if (v > mx) { mx = v; } }
                        return { name: l, max: mx };
                    });
                    option.radar = { indicator: indicators };
                    option.series = [{
                        type: 'radar',
                        data: rawSeries.map(function (s) { return { name: s.name, value: s.y, areaStyle: s.isArea ? {} : undefined }; })
                    }];
                }
                else if (chartType === 'bar' && barHorizontal) {
                    //Horizontal bar: category on the Y Axis, value on the X Axis (orientation set via the echarts_bar_horizontal flag)
                    if (legend) legend.data = rawSeries.map(function (s) { return s.name; });
                    option.tooltip = { trigger: 'axis', axisPointer: { type: 'shadow' }, valueFormatter: function (v) { return fmtY(v); } };
                    option.grid = { containLabel: true, left: '2%', right: '3%', bottom: '2%', top: (title || showLegend) ? 60 : 20 };
                    option.xAxis = { type: 'value', name: xTitle || undefined, axisLabel: { formatter: function (v) { return fmtY(v); } } };
                    option.yAxis = { type: 'category', data: xLabels, name: yTitle || undefined };
                    option.series = rawSeries.map(function (s) {
                        var ser = { name: s.name, type: 'bar', data: s.y };
                        if (barStacked) { ser.stack = 'total'; }
                        if (showLabels) { ser.label = { show: true, position: 'right', formatter: function (p) { return fmtY(p.value); } }; }
                        return ser;
                    });
                }
                else {
                    //Cartesian charts: line, area, bar, scatter, mixed
                    if (legend) legend.data = rawSeries.map(function (s) { return s.name; });
                    option.tooltip = (chartType === 'scatter') ?
                        { trigger: 'item', valueFormatter: function (v) { return fmtY(v); } } :
                        { trigger: 'axis', valueFormatter: function (v) { return fmtY(v); } };

                    //containLabel:true makes ECharts reserve room for the rotated X labels, but the grid's default bottom/left/right (60px / 10%) is then ADDED below/around that label box, leaving a large empty gap under the labels. Use small explicit margins so the chart fills the height; top keeps room for the title/legend.
                    option.grid = { containLabel: true, left: '2%', right: '3%', bottom: '2%', top: (title || showLegend) ? 60 : 20 };
                    option.xAxis = {
                        type: xAxisType,
                        data: xAxisType === 'category' ? xLabels : undefined,
                        name: xTitle || undefined,
                        //By default ECharts hides category labels that would overlap (interval:'auto'); force every label to show and rotate them so they fit, matching the ChartJS rendering. containLabel reserves the extra height.
                        axisLabel: xAxisType === 'category' ? { interval: 0, rotate: 45 } : undefined
                    };
                    option.yAxis = [{ type: yIsTime ? 'time' : 'value', name: yTitle || undefined, axisLabel: { formatter: function (v) { return fmtY(v, false); } } }];
                    if (hasSecondary) {
                        option.yAxis.push({ type: 'value', name: y2Title || undefined, axisLabel: { formatter: function (v) { return fmtY(v, true); } } });
                    }

                    option.series = rawSeries.map(function (s) {
                        var t = 'line';
                        if (chartType === 'mixed') { t = s.mixType; }
                        else if (chartType === 'bar') { t = 'bar'; }
                        else if (chartType === 'scatter') { t = 'scatter'; }
                        var ser = {
                            name: s.name,
                            type: t,
                            yAxisIndex: (hasSecondary && s.secondary) ? 1 : 0,
                            data: pointData(s)
                        };
                        var isArea = (chartType === 'area') || (chartType === 'mixed' && s.isArea);
                        if (t === 'line') { ser.smooth = smooth; if (isArea) { ser.areaStyle = {}; } }
                        //Stacking applies to a pure (vertical) Bar chart via the echarts_bar_stacked flag
                        if (t === 'bar' && chartType === 'bar' && barStacked) { ser.stack = 'total'; }
                        if (showLabels) {
                            ser.label = { show: true, formatter: function (p) { var val = (p.value instanceof Array) ? p.value[p.value.length - 1] : p.value; return fmtY(val, s.secondary); } };
                        }
                        return ser;
                    });
                }

                myChart.setOption(option);
                registerEChartsChart(myChart);

                if (@Helper.ToJS(report.GenerateHTMLDisplay)) {
                    myChart.on('click', function (params) {
                        var idx = params.dataIndex;
                        if (idx !== undefined && idx !== null && idx !== -1 && navigations[idx]) {
                            var ev = (params.event && params.event.event) ? params.event.event : params.event;
                            showPopupNavMenu(ev, navigations[idx], true, '@report.ExecutionGUID');
                        }
                    });
                }
            });//document.ready
        </script>
        chartOk = true;
    }
    if (!chartOk)
    {
        <div class="alert alert-danger" role="alert">
            @Raw(Helper.ToHtml(view.Error))
        </div>
        view.Error = "";
    }
}
