@using Seal.Model;
@{
    ReportViewTemplate Template = Model;

    //Parameters for this template
    Template.Parameters.Add(new Parameter() { Name = "show_information", DisplayName = "Show report information", BoolValue = true, ShowInResultOptions = true, Description = "If true, report information is displayed at the end of the document." });
    Template.Parameters.Add(new Parameter() { Name = "show_messages", DisplayName = "Show messages", BoolValue = false, ShowInResultOptions = true, Description = "If true, report execution messages are displayed at the end of the document." });
    Template.Parameters.Add(new Parameter() { Name = "title_font_size", DisplayName = "Font size: Title", NumericValue = 24, Description = "Font size of the title." });
    Template.Parameters.Add(new Parameter() { Name = "title_font_color", DisplayName = "Font color: Title", Value = "#29778b", Description = "Font color of the title." });
    Template.Parameters.Add(new Parameter() { Name = "messages_font_size", DisplayName = "Font size: Messages", NumericValue = 8, Description = "Font size of the report execution messages." });
    Template.Parameters.Add(new Parameter() { Name = "footer_font_size", DisplayName = "Font size: Footer", NumericValue = 10, Description = "Font size of the footer texts." });
    Template.Parameters.Add(new Parameter() { Name = "tabpage_show_entire", DisplayName = "Tab page: Force entire", BoolValue = false, Description = "If true, 'Tab Page' views are shown on the same page. This may cause Layout Exception if its content requires more space than is available on the page." });
    Template.Parameters.Add(new Parameter() { Name = "widget_show_entire", DisplayName = "Widget: Force entire", BoolValue = false, Description = "If true, 'Widget' views are shown on the same page. This may cause Layout Exception if its content requires more space than is available on the page." });
    Template.Parameters.Add(new Parameter()
            {
                Name = "page_size",
                DisplayName = "Page size",
                Description = "Define the size of the pages of the document.",
                Value = "A4",
                ShowInResultOptions = true,
                UseOnlyEnumValues = true,
                Enums = (from i in typeof(QuestPDF.Helpers.PageSizes).GetProperties() select i.Name).ToArray()
            });
    Template.Parameters.Add(new Parameter() { Name = "page_orientation", DisplayName = "Page orientation", Value="portrait", ShowInResultOptions = true, Description = "Define the pages orientation.", Enums = new string[] { "portrait|Portrait", "landscape|Landscape" } });
    Template.Parameters.Add(new Parameter() { Name = "force_charts", DisplayName = "Charts: Force ScottPlot", BoolValue = true, Description = "If true, charts are converted to ScottPlot charts for a better rendering." });

    // QuestPDF Companion integration
    Template.Parameters.Add(new Parameter() { Name = "show_in_companion", DisplayName = "Show report in QuestPDF companion app", BoolValue = false, Description = "If true, report is generated in the quest pdf companion app. The app must be opened and show 'Active and Listening' in the port settings." });
    Template.Parameters.Add(new Parameter() { Name = "companion_port", DisplayName = "Port configured in QuestPDF companion app", NumericValue = 12500, Description = "Change port value to match the configured value in Companion settings, default is 12500." });
}