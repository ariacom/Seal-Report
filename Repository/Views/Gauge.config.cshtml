@using Seal.Model;
@{
    ReportViewTemplate Template = Model;
    Template.Description = "Display a Gauge built with Apache ECharts from a data table result having at least 1 row and 1 column for the value. 3 optionals columns can be used to set the minimum, the maximum and the animation speed. Full description of the gauge options at https://echarts.apache.org/en/option.html#series-gauge";

    //If true, the view is a child of a report model view
    Template.IsModelViewChild = true;

    //Parameters for this template
    Template.Parameters.Add(new Parameter() { Name = "gauge_class", DisplayName = "CSS class: Container", TextValue = "text-center", Description = "CSS class attribute of the main DIV container.", Enums = new string[] { "text-center;" }, UseOnlyEnumValues = false });
    Template.Parameters.Add(new Parameter() { Name = "gauge_css", DisplayName = "CSS style: Container", TextValue = "page-break-inside:avoid", Description = "CSS style attribute of the main DIV container.", Enums = new string[] { "margin:10px;", "padding:10px;" }, UseOnlyEnumValues = false });
    Template.Parameters.Add(new Parameter() { Name = "gauge_width", DisplayName = "Gauge width", NumericValue = 250, Description = "The gauge width in pixels. If 0, a default width is used." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_height", DisplayName = "Gauge height", NumericValue = 250, Description = "The gauge height in pixels. If 0, a default height is used." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_min", DisplayName = "Minimum value", TextValue = "0", Description = "The minimum value of the gauge. Can be overwritten by the second value of the result table." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_max", DisplayName = "Maximum value", TextValue = "", Description = "The maximum value of the gauge. If empty, the value is used for the maximum. Can be overwritten by the third value of the result table." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_animation", DisplayName = "Animation duration", NumericValue = 1000, Description = "The animation duration of the gauge in milliseconds. If 0, the animation is disabled. Can be overwritten by the fourth value of the result table." });

    Template.Parameters.Add(new Parameter() { Name = "gauge_start_angle", DisplayName = "Start angle", NumericValue = 225, Description = "The start angle of the gauge (ECharts angle, 0 is at 3 o'clock, positive is counter-clockwise). Default is 225. Use 180 and 0 (end angle) for a half-gauge." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_end_angle", DisplayName = "End angle", NumericValue = -45, Description = "The end angle of the gauge. Default is -45. Use 180 (start angle) and 0 for a half-gauge." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_splitnumber", DisplayName = "Split number", NumericValue = 5, Description = "The number of major divisions (split) of the gauge axis." });

    Template.Parameters.Add(new Parameter() { Name = "gauge_axisline_width", DisplayName = "Axis line width", NumericValue = 18, Description = "The width in pixels of the gauge axis line (the colored arc)." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_colors", DisplayName = "Colors (zones)", TextValue = "", Description = "Color zones of the gauge axis line, as a list of [stop,color] pairs where stop is a ratio between 0 and 1 (the last stop must be 1). If empty, a single color is used.", TextSamples = new string[] { "[0.3,'#30B32D'],\r\n[0.7,'#FFDD00'],\r\n[1,'#F03E3E']\r\n", "[0.5,'#a9d70b'],\r\n[0.75,'#f9c802'],\r\n[1,'#ff0000']\r\n" } });

    Template.Parameters.Add(new Parameter() { Name = "gauge_show_progress", DisplayName = "Show progress", BoolValue = false, Description = "If true, a progress arc is drawn from the minimum up to the current value." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_show_pointer", DisplayName = "Show pointer", BoolValue = true, Description = "If true, the pointer (needle) is displayed on the gauge." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_show_axislabel", DisplayName = "Show axis labels", BoolValue = true, Description = "If true, the scale labels (numbers) are displayed around the gauge." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_show_splitline", DisplayName = "Show split lines", BoolValue = true, Description = "If true, the major tick lines are displayed on the gauge axis." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_show_ticks", DisplayName = "Show minor ticks", BoolValue = true, Description = "If true, the minor tick lines are displayed on the gauge axis." });

    Template.Parameters.Add(new Parameter() { Name = "gauge_title", DisplayName = "Title", TextValue = "", Description = "Optional title (name) displayed with the gauge value." });
    Template.Parameters.Add(new Parameter() { Name = "gauge_value_format", DisplayName = "Value format", TextValue = "{value}", Description = "The format of the value displayed in the center of the gauge. Use the keyword {value} for the value (e.g. '{value} $').", TextSamples = new string[] { "{value}", "{value} $", "{value}%" } });
    Template.Parameters.Add(new Parameter() { Name = "gauge_value_color", DisplayName = "Value color", TextValue = "", Description = "The color of the value displayed in the center of the gauge. If empty, the ECharts default color is used.", Enums = new string[] { "", "black", "green", "#5470c6" }, UseOnlyEnumValues = false });
    Template.Parameters.Add(new Parameter() { Name = "gauge_value_fontsize", DisplayName = "Value font size", NumericValue = 0, Description = "The font size in pixels of the value displayed in the center of the gauge. If 0, the ECharts default size is used." });

    Template.Parameters.Add(new Parameter() { Name = "gauge_options", DisplayName = "Advanced options", TextValue = "", Description = "Advanced ECharts gauge series options (a JavaScript object) deep-merged into the generated gauge series. Use it to set any ECharts gauge option not exposed above. See https://echarts.apache.org/en/option.html#series-gauge", TextSamples = new string[] { "axisLine:{ roundCap:true },\r\nprogress:{ roundCap:true }\r\n", "anchor:{ show:true, showAbove:true, size:18, itemStyle:{ color:'#FAC858' } }\r\n" } });

    //Allowed template parent names
    Template.ParentNames = new List<string>() { "Model", "Container", "Container Grid Flex", "Widget", "Tab Page" };
}
