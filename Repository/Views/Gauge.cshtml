@using Seal.Model
@using Seal.Helpers
@{
    Report report = Model;
    ReportView view = report.CurrentView;
    ReportView modelView = view.ModelView;
    ReportModel reportModel = modelView.Model;
    ResultPage page = report.CurrentPage;
    if (page == null) { return; }

    string gaugeId = "g" + Helper.NewGUID();
    //The container is identified for the PDF renderer (screenshot of the bounding box)
    page.SetIdentifier(ResultPageIdentifierType.GaugeCanvas, gaugeId);

    ResultTable table = page.DataTable;
    string value = null, min = null, max = null, animation = null;
    if (table.ColumnCount > 0 && table.RowCount > 1)
    {
        value = table[table.BodyStartRow, 0].Value.ToString();
        if (table.ColumnCount > 1) {
            min = table[table.BodyStartRow, 1].Value.ToString();
        }
        if (table.ColumnCount > 2) {
            max = table[table.BodyStartRow, 2].Value.ToString();
        }
        if (table.ColumnCount > 3) {
            animation = table[table.BodyStartRow, 3].Value.ToString();
        }
    }

    if (value == null)
    {
        throw new Exception("No value in the result table of the model.");
    }

    min = min ?? view.GetValue("gauge_min");
    max = max ?? view.GetValue("gauge_max");
    animation = animation ?? view.GetValue("gauge_animation");

    //If no maximum is defined, the value is used as the maximum
    if (string.IsNullOrEmpty(min)) { min = "0"; }
    if (string.IsNullOrEmpty(max)) { max = value; }
    if (string.IsNullOrEmpty(animation)) { animation = "1000"; }

    int width = view.GetNumericValue("gauge_width"); if (width <= 0) { width = 250; }
    int height = view.GetNumericValue("gauge_height"); if (height <= 0) { height = 250; }
    int fontSize = view.GetNumericValue("gauge_value_fontsize");

    var colors = view.GetValue("gauge_colors");
    var advanced = view.GetValue("gauge_options");
}

<div id="@gaugeId" class="@Raw(view.GetValue("gauge_class"))" style="@Raw(Helper.AddIfNotEmpty("", view.GetValue("gauge_css"), ";"))margin-left:auto;margin-right:auto;width:@(width)px;height:@(height)px;"></div>

<script>
$(document).ready(function () {
    var dom = document.getElementById('@gaugeId');
    var myChart = echarts.init(dom);

    var axisColor = @Raw(string.IsNullOrEmpty(colors) ? "[[1, '#5470c6']]" : "[" + colors + "]");
    var valueColor = '@Raw(Helper.ToJS(view.GetValue("gauge_value_color")))';

    var series = {
        type: 'gauge',
        min: @min,
        max: @max,
        splitNumber: @view.GetNumericValue("gauge_splitnumber"),
        startAngle: @view.GetNumericValue("gauge_start_angle"),
        endAngle: @view.GetNumericValue("gauge_end_angle"),
        axisLine: { lineStyle: { width: @view.GetNumericValue("gauge_axisline_width"), color: axisColor } },
        progress: { show: @view.GetBoolValueJS("gauge_show_progress"), width: @view.GetNumericValue("gauge_axisline_width") },
        pointer: { show: @view.GetBoolValueJS("gauge_show_pointer") },
        axisTick: { show: @view.GetBoolValueJS("gauge_show_ticks") },
        splitLine: { show: @view.GetBoolValueJS("gauge_show_splitline") },
        axisLabel: { show: @view.GetBoolValueJS("gauge_show_axislabel") },
        title: { show: @Helper.ToJS(!string.IsNullOrEmpty(view.GetValue("gauge_title"))) },
        detail: {
            valueAnimation: true,
            formatter: '@Raw(Helper.ToJS(view.GetValue("gauge_value_format")))'
        },
        data: [{ value: @value, name: '@Raw(Helper.ToJS(modelView.GetTranslatedMappedLabel(view.GetValue("gauge_title"))))' }]
    };
    if (valueColor) series.detail.color = valueColor;
    @if (fontSize > 0)
    {
        <text>series.detail.fontSize = @fontSize;</text>
    }

    //Deep-merge the advanced ECharts gauge options provided by the user
    @if (!string.IsNullOrEmpty(advanced))
    {
        <text>
        (function deepMerge(target, source) {
            for (var k in source) {
                if (source[k] && typeof source[k] === 'object' && !(source[k] instanceof Array) && target[k] && typeof target[k] === 'object') {
                    deepMerge(target[k], source[k]);
                } else {
                    target[k] = source[k];
                }
            }
        })(series, { @Raw(advanced) });
        </text>
    }

    var option = {
        animationDuration: @animation,
        series: [series]
    };

    myChart.setOption(option);
    registerEChartsChart(myChart);
});
</script>
