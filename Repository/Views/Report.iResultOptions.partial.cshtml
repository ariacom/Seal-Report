@using Seal.Model
@using Seal.Helpers
@{
    ReportView view = Model;
    Report report = view.Report;
    Repository repository = report.Repository;
}

@if (report.GenerateHTMLDisplay || !report.PrintLayout)
{            
    <script>
        $(document).ready(function () {
            $('#ResultOptions').click(function (e) {
                e.preventDefault();
                $(this).closest('.open').removeClass('open'); // closes the dropdown
                bootstrap.Modal.getOrCreateInstance(document.getElementById('result-options-modal')).show();
                return false;
            });        
            
            $('.result-options-input').unbind("input keyup change").on("input keyup change", (e) => {
                if ($(e.target).hasClass("numeric_input")) e.target.value = e.target.value.replace(/[^0-9\.]/g, '');
                processSubmitViewParameter(e.target.id, e.target.value, '@view.ViewId', true);
            });
            
            $('.result-options-select').selectpicker();
            $('.result-options-select').on("change", (e) => {
                const values = $(e.target).val();
                const joined = Array.isArray(values) ? values.join('|') : values;
                processSubmitViewParameter(e.target.id, joined, '@view.ViewId', true);
            });
            
            
        });
    </script>
                                
    <!-- Result Options modal -->
    <div id="result-options-modal" class="modal fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
        <div class="modal-dialog" style="width: 900px; max-width: 95vw;">
            <div class="modal-content" style="top:60px;">
                <div class="modal-header">
                    <h4 class="modal-title">@report.Translate("Report result options")</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" style="height:600px;overflow:auto;">
                    @foreach(var parameter in report.ResultOptionParameters)
                    {
                        var name = parameter.ResultOptionName;
                        
                        <div class="row mb-3 align-items-center">
                            <label class="form-label col-sm-6 mb-0" style="text-align:left;overflow:hidden;cursor:default;" for='@name'>
                                @Raw(Helper.ToHtml(parameter.ResultOptionDisplayName))
                            </label>

                            @if (parameter.Type == ViewParameterType.Enum) {
                                var multiple = "";
                                if (name == "|tabs") multiple = "multiple";

                                <div class='col-sm-6'>
                                    <select name='@name' id='@name' class='result-options-select' @multiple data-actions-box='true' data-width='100%'>
                                        @foreach(var val in parameter.EnumValues)
                                        {
                                            <option id='@val' value='@val' @(parameter.MultipleEnumValues.Contains(val) ? "selected" : "")>@Raw(Helper.ToHtml(@report.Translate(parameter.EnumGetDisplayFromValue(val))))
                                            </option>
                                        }
                                    </select>
                                </div>
                            }
                            else if (parameter.Type == ViewParameterType.Boolean) {
                                <div class='col-sm-6'>
                                    <div class="btn-group" id='@name'>
                                        <input type="radio" class="btn-check result-options-input" name='@name' id='@(name)_true' value='True' autocomplete="off" @(parameter.BoolValue ? "checked" : "")>
                                        <label class="btn btn-secondary" for='@(name)_true'>@report.Translate("Yes")</label>
                                        <input type="radio" class="btn-check result-options-input" name='@name' id='@(name)_false' value='False' autocomplete="off" @(!parameter.BoolValue ? "checked" : "")>
                                        <label class="btn btn-secondary" for='@(name)_false'>@report.Translate("No")</label>
                                    </div>
                                </div>
                            }
                            else if (parameter.Type == ViewParameterType.Numeric) {
                                <div class='col-sm-6'>
                                    <input type='text' name='@name' id='@name' class='result-options-input form-control numeric_input' value='@parameter.Value'/>
                                </div>
                            }
                            else {
                                <div class='col-sm-6'>
                                    <input type='text' name='@name' id='@name' class='result-options-input form-control' value='@parameter.Value'/>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@report.Translate("Close")</button>
                </div>
            </div>
        </div>
    </div>
} 
