      <MetaEnum>
        <GUID>aab33159-0000-4000-8000-000000000010</GUID>
        <Name>AI Providers</Name>
        <IsDynamic>true</IsDynamic>
        <IsDbRefresh>true</IsDbRefresh>
        <Script>@using Seal.Model
@using Seal.AI
@using System.Linq
@{
    MetaEnum enumList = Model;
    enumList.Values.Clear();
    foreach (var provider in Repository.Instance.AIConfiguration.AIProviders.Where(p =&gt; p.IsEnabled).OrderBy(p =&gt; p.Name))
    {
        enumList.Values.Add(new MetaEV() { Id = provider.GUID, Val = provider.Name });
    }
}
</Script>
