          </MetaColumn>
          <MetaColumn>
            <GUID>067548ce-bc83-48b8-8212-aa359bd12f9b</GUID>
            <Description>Net line amount: quantity times unit price, less the discount.</Description>
            <Name>(1-[Order Details].Discount)*[Order Details].Quantity*[Order Details].UnitPrice</Name>
