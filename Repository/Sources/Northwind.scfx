            <Name>[Order Details].Discount*[Order Details].Quantity*[Order Details].UnitPrice</Name>
            <Type>Numeric</Type>
            <Category>Order Details</Category>
            <Tag>Master</Tag>
            <DisplayName>Discount</DisplayName>
