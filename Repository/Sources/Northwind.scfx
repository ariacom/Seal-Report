        <GUID>b9126304-1091-45e0-93e6-c2f028c02f8f</GUID>
        <Description>List of products, cascaded from the currently selected Category.</Description>
        <Name>Product Name</Name>
        <IsDynamic>true</IsDynamic>
        <IsDbRefresh>true</IsDbRefresh>
        <Sql>SELECT ProductID, ProductName 
FROM Products
ORDER BY ProductName</Sql>
        <Translate>true</Translate>
        <Message>Please select a Category first</Message>
        <SqlDisplay>SELECT ProductID, ProductName 
FROM Products
WHERE CategoryID IN ({EnumValues_Category})
ORDER BY ProductName</SqlDisplay>
