@using Seal.Model;
@{
    ReportTask task = Model;

    task.TemplateDescription = "Cancels a report output based on a condition evaluated by AI on the report data.";
    task.Step = ExecutionStep.BeforeRendering;

    task.Parameters.Add(new Parameter() { Name = "ai_assistant_name", Value = "", DisplayName = "AI Assistant name", Description = "The AI Assistant name. If empty, the default assistant is used (if configured).", Enums = (from a in Repository.Instance.Configuration.AIAssistants where a.IsEnabled select a.Name).ToArray(), UseOnlyEnumValues = false });
    task.Parameters.Add(new Parameter() { Name = "ai_system_prompt", Value = "You are a report output controller for a business reporting system.\r\nYour sole responsibility is to decide whether a report output should be cancelled or published, based on data values extracted from the report.\r\n\r\nOutput format — respond with a JSON object containing exactly two fields:\r\n- \"cancel\": boolean. true = cancel the output. false = publish the output.\r\n- \"reason\": a single sentence stating the value found and whether the condition was met.\r\n\r\nThe \"reason\" field must always be consistent with the \"cancel\" field:\r\n- If cancel is true, reason must confirm the condition was met and the output is cancelled.\r\n- If cancel is false, reason must confirm the condition was not met and the output is published.\r\n\r\nRules:\r\n- Do not add any text, markdown, or commentary outside the JSON object.\r\n- Base your decision strictly on the condition provided in the user message.\r\n- Use the DATA rows as the primary source for numeric values.\r\n- If the relevant value cannot be found in the data, set cancel to false and explain in reason.\r\n- Evaluate the condition first, set cancel accordingly, then write reason to match.", DisplayName = "AI System prompt", Description = "The system prompt sent to the AI provider." });
    task.Parameters.Add(new Parameter() { Name = "ai_system_additional", TextValue = "", DisplayName = "Additional system prompt", Description = "Additional system information for the AI provider." });
    task.Parameters.Add(new Parameter() { Name = "ai_user_prompt", Value = "Cancel the report output if [describe your cancellation condition here].", DisplayName = "AI User prompt", Description = "The condition to evaluate. Describe what data value and threshold should trigger a cancellation." });
    task.Parameters.Add(new Parameter() { Name = "ai_user_additional", TextValue = "Apply the condition and respond with your decision in JSON format.", DisplayName = "Additional user prompt", Description = "Additional instruction appended to the user prompt. Controls the expected response format — do not change this unless you know the required JSON structure." });
    task.Parameters.Add(new Parameter() { Name = "check_model", Value = "", DisplayName = "Model to check", Description = "The model name to check. If empty, all models of the report are taken." });
    task.Parameters.Add(new Parameter() { Name = "log_ai_requests", BoolValue = false, DisplayName = "Log requests and responses", Description = "If enabled, logs the full system prompt, user prompt and AI response to the task execution log." });

    task.Script = @"@using Seal.AI;
@using Newtonsoft.Json.Linq;
@{
    ReportTask task = Model;
    Report report = task.Report;

    task.LogMessage($""Executing '{task.Name}'"");

    //Check only for report output
    if (report.OutputToExecute == null) return;

    var assistantName = task.GetValue(""ai_assistant_name"");
    var system = task.GetValue(""ai_system_prompt"");
    var systemAdditional = task.GetValue(""ai_system_additional"");
    var user = task.GetValue(""ai_user_prompt"");
    var userAdditional = task.GetValue(""ai_user_additional"");
    var modelName = task.GetValue(""check_model"");
    var logRequests = task.GetBoolValue(""log_ai_requests"", false);

    var dataJson = """";
    foreach (var model in report.Models.Where(i => string.IsNullOrEmpty(modelName) || i.Name == modelName)) {
        var (tableJson, aggJson) = model.ResultTableTranslatedJson;
        dataJson += $@""=== Model: {model.Name} ===
PRE-AGGREGATED METRICS:
{aggJson}

DATA:
{tableJson}

"";
    }
	if (string.IsNullOrEmpty(dataJson)) throw new Exception(""No data found. Check your model name"");

    system += $""\r\nRespond with language and regional settings of culture {report.ExecutionView.CultureInfo.Name}.\r\n{systemAdditional}"";
    user += $""\r\n{userAdditional}\r\n{dataJson}"";

    if (logRequests) {
		task.LogMessage($""[AI Request {system.Length}] System:\r\n{system}"");
		task.LogMessage($""[AI Request {user.Length}] User:\r\n{user}"");
    }
    var assistant = new AIAssistant(assistantName);
    assistant.OverrideSystemPrompt(system);
    var answer = assistant.Chat(user);
    if (logRequests) task.LogMessage($""[AI Response]\r\n{answer}"");
    JObject obj = JObject.Parse(answer);

    bool cancel = obj[""cancel""].Value<bool>();
    string reason = obj[""reason""].Value<string>();

    if (cancel) {
        report.Cancel = true;
        report.ExecutionErrors = reason;
    }
}
";

    task.BodyScript = ReportTask.BodyScriptTemplate;
}
