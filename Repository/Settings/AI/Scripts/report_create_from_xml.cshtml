@using System.IO
@using System.Linq
@using System.Text
@using System.Text.Json
@using System.Text.RegularExpressions
@using System.Xml.Linq
@using Seal.Model
@using Seal.AI
@{
    AIToolConfiguration tool = Model;
    var repo            = Repository.Instance;
    var securityContext = tool.CurrentToolCall.SecurityContext;
    if (securityContext == null) { tool.ExecResult = "Error: no security context available."; return; }

    var args      = JsonDocument.Parse(tool.CurrentToolCall.Arguments).RootElement;
    var path      = args.GetProperty("path").GetString();
    tool.CurrentToolCall.LogMessage($"Starting tool '{tool.CurrentToolCall.Name}' (path: {path})..");
    var xml       = args.GetProperty("xml").GetString();
    var overwrite = args.TryGetProperty("overwrite", out var op) && op.GetBoolean();

    var roots = new System.Collections.Generic.Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Reports"]  = repo.ReportsFolder,
        ["Personal"] = repo.GetPersonalFolder(securityContext),
    };

    string fullPath = null;
    foreach (var kv in roots)
        if (path.StartsWith(kv.Key + Path.DirectorySeparatorChar, StringComparison.OrdinalIgnoreCase))
            { fullPath = Path.Combine(kv.Value, path.Substring(kv.Key.Length + 1)); break; }
    if (fullPath == null) fullPath = Path.Combine(repo.ReportsFolder, path);
    if (!fullPath.EndsWith("." + Repository.SealReportFileExtension, StringComparison.OrdinalIgnoreCase))
        fullPath += "." + Repository.SealReportFileExtension;

    if (File.Exists(fullPath) && !overwrite)
        { tool.ExecResult = $"Error: '{path}' already exists. Set overwrite=true to replace it."; return; }


    if (!securityContext.HasFolderRight(Path.GetDirectoryName(fullPath), (int)FolderRight.Edit))
        { tool.ExecResult = $"Error: write access denied to '{path}'."; return; }

    try
    {
        var doc = XDocument.Parse(xml);

        // --- Validate / resolve metadata column references (guard against fabricated GUIDs) ---
        Func<string, string> norm = s => (s ?? "").Replace("[", "").Replace("]", "").Trim().ToLowerInvariant();

        var msGuid = doc.Descendants("MetaSourceGUID")
                        .Select(e => e.Value == null ? null : e.Value.Trim())
                        .FirstOrDefault(v => !string.IsNullOrEmpty(v));
        var metaSource = repo.Sources.FirstOrDefault(s => string.Equals(s.GUID, msGuid, StringComparison.OrdinalIgnoreCase));
        if (metaSource == null)
        {
            tool.ExecResult = $"Error: MetaSourceGUID '{msGuid}' does not match any data source. Use the GUID from datasource_list.";
            return;
        }

        var validColGuids = new System.Collections.Generic.HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var colGuidByName = new System.Collections.Generic.Dictionary<string, string>();
        var colNameByGuid = new System.Collections.Generic.Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var table in metaSource.MetaData.Tables)
            foreach (var col in table.Columns)
            {
                validColGuids.Add(col.GUID);
                colGuidByName[norm(col.Name)] = col.GUID;
                if (!string.IsNullOrEmpty(col.DisplayName)) colGuidByName[norm(col.DisplayName)] = col.GUID;
                colNameByGuid[col.GUID] = col.Name;
            }

        var badRefs = new System.Collections.Generic.List<string>();
        foreach (var mc in doc.Descendants("MetaColumnGUID").ToList())
        {
            var val = mc.Value == null ? "" : mc.Value.Trim();
            if (!validColGuids.Contains(val))
            {
                var refName = mc.Parent == null ? null : (string)mc.Parent.Element("Name");
                string realGuid;
                if (refName != null && colGuidByName.TryGetValue(norm(refName), out realGuid))
                {
                    tool.CurrentToolCall.LogMessage($"Resolved MetaColumnGUID for '{refName.Trim()}': '{val}' -> '{realGuid}'");
                    mc.Value = realGuid;
                    val = realGuid;
                }
                else
                {
                    badRefs.Add(refName != null ? $"'{refName.Trim()}' (supplied GUID '{val}')" : $"GUID '{val}'");
                    continue;
                }
            }

            // NoSQL sources resolve each element/restriction in memory by matching its <Name>
            // to a result-table column, whose name is the metadata column's raw field name
            // (e.g. 'year', 'transactions.amount'). A table-qualified name like 'transactions.year'
            // matches nothing and the report fails. Force <Name> to the raw field name.
            if (metaSource.IsNoSQL && mc.Parent != null && colNameByGuid.TryGetValue(val, out var rawName))
            {
                var nameEl = mc.Parent.Element("Name");
                if (nameEl == null) mc.Parent.AddFirst(new XElement("Name", rawName));
                else if (nameEl.Value != rawName)
                {
                    tool.CurrentToolCall.LogMessage($"NoSQL: corrected element Name '{nameEl.Value}' -> '{rawName}'");
                    nameEl.Value = rawName;
                }
            }
        }
        if (badRefs.Count > 0)
        {
            tool.ExecResult = "Error: these MetaColumnGUID values are not columns of source '" + metaSource.Name +
                "': " + string.Join("; ", badRefs) +
                ". Call datasource_get_detail and copy the exact column GUIDs - never invent or sequence GUIDs.";
            return;
        }

        // --- Validate restrictions (guard against definitions the engine silently ignores) ---
        // An enumerated restriction is applied only when its operator is Equal/NotEqual and
        // <EnumValues> is filled: a <Value1> or a text operator (Contains, StartsWith...) makes
        // the engine treat it as "not filled" and skip it, so the report runs UNFILTERED with
        // no error. Reject such definitions so the caller can fix the XML.
        var colByGuid = new System.Collections.Generic.Dictionary<string, MetaColumn>(StringComparer.OrdinalIgnoreCase);
        foreach (var table in metaSource.MetaData.Tables)
            foreach (var col in table.Columns)
                colByGuid[col.GUID] = col;

        var restrictionErrors   = new System.Collections.Generic.List<string>();
        var restrictionWarnings = new System.Collections.Generic.List<string>();
        var valueLessOperators  = new System.Collections.Generic.HashSet<string>(StringComparer.OrdinalIgnoreCase)
            { "IsNull", "IsNotNull", "IsEmpty", "IsNotEmpty" };

        foreach (var rest in doc.Descendants("ReportRestriction"))
        {
            var colGuid = rest.Element("MetaColumnGUID") == null ? null : rest.Element("MetaColumnGUID").Value.Trim();
            MetaColumn rcol = null;
            if (colGuid == null || !colByGuid.TryGetValue(colGuid, out rcol)) continue;
            var menum = string.IsNullOrEmpty(rcol.EnumGUID) ? null : metaSource.MetaData.Enums.FirstOrDefault(e => e.GUID == rcol.EnumGUID);
            if (menum == null) continue;

            var restName = rest.Element("Name") != null && !string.IsNullOrEmpty(rest.Element("Name").Value) ? rest.Element("Name").Value.Trim() : rcol.Name;
            var op       = rest.Element("Operator") != null ? rest.Element("Operator").Value.Trim() : "Equal";
            var enumEls  = rest.Element("EnumValues") == null ? new System.Collections.Generic.List<XElement>() : rest.Element("EnumValues").Elements("string").ToList();
            var hasVal1  = rest.Element("Value1") != null && !string.IsNullOrEmpty(rest.Element("Value1").Value);
            var prompted = rest.Element("Prompt") != null && rest.Element("Prompt").Value.Trim() != "None";

            if (valueLessOperators.Contains(op)) continue;

            if (op != "Equal" && op != "NotEqual")
            {
                restrictionErrors.Add($"'{restName}': operator '{op}' is invalid on an enumerated column (only Equal or NotEqual are supported)");
                continue;
            }
            if (hasVal1 && enumEls.Count == 0)
            {
                restrictionErrors.Add($"'{restName}': <Value1> is ignored on an enumerated column, list the values as <EnumValues><string>value</string></EnumValues>");
                continue;
            }
            if (enumEls.Count == 0 && !prompted)
            {
                restrictionErrors.Add($"'{restName}': static (not prompted) restriction has no <EnumValues>, it would be skipped at execution");
                continue;
            }

            // EnumValues must contain the enum value ids: map display labels back to their id,
            // and warn about values unknown to the enumerated list (dynamic lists may be stale,
            // so an unknown value is not a hard error).
            if (enumEls.Count > 0 && menum.Values.Count > 0)
            {
                foreach (var vEl in enumEls)
                {
                    var v = vEl.Value;
                    if (menum.Values.Any(ev => ev.Id == v)) continue;
                    var byLabel = menum.Values.FirstOrDefault(ev => (!string.IsNullOrEmpty(ev.Val) && ev.Val == v) || ev.DisplayValue == v);
                    if (byLabel != null)
                    {
                        tool.CurrentToolCall.LogMessage($"Restriction '{restName}': mapped enum label '{v}' -> id '{byLabel.Id}'");
                        vEl.Value = byLabel.Id;
                    }
                    else restrictionWarnings.Add($"'{restName}': value '{v}' is not in the enumerated list '{menum.Name}' (the filter may match nothing)");
                }
            }
        }

        // A restriction defined in <Restrictions>/<AggregateRestrictions> but not referenced in
        // the model's <Restriction>/<AggregateRestriction> expression is silently inactive.
        foreach (var model in doc.Descendants("ReportModel"))
        {
            foreach (var pair in new[] { new[] { "Restriction", "Restrictions" }, new[] { "AggregateRestriction", "AggregateRestrictions" } })
            {
                var exprText = model.Element(pair[0]) == null ? "" : model.Element(pair[0]).Value;
                var defs     = model.Element(pair[1]) == null ? new System.Collections.Generic.List<XElement>() : model.Element(pair[1]).Elements("ReportRestriction").ToList();
                foreach (var rest in defs)
                {
                    var g = rest.Element("GUID") == null ? null : rest.Element("GUID").Value.Trim();
                    if (string.IsNullOrEmpty(g) || exprText.Contains("[" + g + "]")) continue;
                    var n = rest.Element("Name") != null ? rest.Element("Name").Value.Trim() : g;
                    restrictionErrors.Add($"'{n}': defined in <{pair[1]}> but not referenced in the <{pair[0]}> expression, it would be inactive - add [{g}] to the expression or remove the restriction");
                }
            }
        }

        if (restrictionErrors.Count > 0)
        {
            tool.ExecResult = "Error: invalid restriction definition(s): " + string.Join("; ", restrictionErrors) +
                ". Enumerated columns accept only Equal/NotEqual with <EnumValues><string>value</string></EnumValues>" +
                " (a <Value1> or another operator is silently ignored at execution). Fix the XML and call report_create_from_xml again.";
            return;
        }

        // Only regenerate internal cross-reference GUIDs.
        // MetaSourceGUID and MetaColumnGUID must be preserved — they reference
        // actual repository metadata objects and must be supplied correctly by the caller.
        var internalNames = new System.Collections.Generic.HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "GUID", "ViewGUID", "SourceGUID", "ModelGUID"
        };

        // Build old→new map from all internal GUID elements
        var guidMap = new System.Collections.Generic.Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var el in doc.Descendants())
        {
            if (!internalNames.Contains(el.Name.LocalName)) continue;
            var val = el.Value?.Trim();
            if (!string.IsNullOrEmpty(val) && !guidMap.ContainsKey(val))
                guidMap[val] = Guid.NewGuid().ToString();
        }

        // Rewrite internal GUID elements with the new values
        foreach (var el in doc.Descendants())
        {
            if (!internalNames.Contains(el.Name.LocalName)) continue;
            var val = el.Value?.Trim();
            if (!string.IsNullOrEmpty(val) && guidMap.TryGetValue(val, out var rep))
                el.Value = rep;
        }

        // Rewrite GUID references inside <Restriction> and <AggregateRestriction> text.
        // The format is [key] where key may be a real GUID or any short placeholder (e.g. f1).
        // Match anything inside brackets and remap it if found in guidMap.
        var restrictionNames = new System.Collections.Generic.HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "Restriction", "AggregateRestriction"
        };
        foreach (var el in doc.Descendants())
        {
            if (!restrictionNames.Contains(el.Name.LocalName) || string.IsNullOrEmpty(el.Value)) continue;
            el.Value = Regex.Replace(el.Value,
                @"\[([^\]]+)\]",
                m => {
                    var inner = m.Groups[1].Value;
                    return guidMap.TryGetValue(inner, out var rep) ? "[" + rep + "]" : m.Value;
                });
        }

        var sb = new StringBuilder();
        if (doc.Declaration != null) { sb.Append(doc.Declaration).Append("\r\n"); }
        sb.Append(doc.ToString());

        var dir = Path.GetDirectoryName(fullPath);
        if (!Directory.Exists(dir)) Directory.CreateDirectory(dir);
        File.WriteAllText(fullPath, sb.ToString(), System.Text.Encoding.UTF8);

        tool.ExecResult = $"Created: {path}";
        if (restrictionWarnings.Count > 0)
            tool.ExecResult += "\r\nWarning: " + string.Join("; ", restrictionWarnings) +
                ". Verify the values with database_get_sample_values and recreate the report with overwrite=true if they are wrong.";
    }
    catch (Exception ex) { tool.ExecResult = $"Error: {ex.Message}"; }
    tool.CurrentToolCall.LogMessage($"Tool '{tool.CurrentToolCall.Name}' finished.");
}
