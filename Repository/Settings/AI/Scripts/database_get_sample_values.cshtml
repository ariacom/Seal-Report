@using System.Text.Json
@using System.Text
@using Seal.Model
@using Seal.Helpers
@using Seal.AI
@{
    AIToolConfiguration tool = Model;
    var securityContext = tool.CurrentToolCall.SecurityContext;
    if (securityContext == null) { tool.ExecResult = "Error: no security context available."; return; }
    if (!securityContext.SqlModel) { tool.ExecResult = "Error: you are not allowed to query the database (SQL Models are disabled for your security group). Do not retry with other database tools and do not suggest technical workarounds: tell the user in one sentence that their profile does not allow direct database queries and that an administrator can enable 'SQL models' for their security group, then offer to run existing reports instead (report_list)."; return; }

    var args       = JsonDocument.Parse(tool.CurrentToolCall.Arguments).RootElement;
    var tableName  = args.GetProperty("table").GetString();
    var columnName = args.GetProperty("column").GetString();
    tool.CurrentToolCall.LogMessage($"Starting tool '{tool.CurrentToolCall.Name}' (table: {tableName}, column: {columnName})..");
    var dsGuid     = args.TryGetProperty("datasource_guid", out var dsp) ? dsp.GetString() : null;
    var connGuid   = args.TryGetProperty("connection_guid", out var cnp) ? cnp.GetString() : null;
    var source     = tool.GetExecSource(dsGuid);
    if (source == null) { tool.ExecResult = "Error: no data source configured."; return; }

    // NoSQL source: read distinct values from the materialized table (LINQ over the DataTable)
    if (source.IsNoSQL) {
        var ntable = source.MetaData.Tables.FirstOrDefault(t => t.Name == tableName || t.DisplayName == tableName || t.Alias == tableName);
        if (ntable == null) { tool.ExecResult = $"No table '{tableName}' found in NoSQL source '{source.Name}'."; return; }
        try {
            // Mirror the framework pattern: MongoDB loads a definition preview (~100 docs); other NoSQL loads full data
            var ndt = ntable.BuildNoSQLTable(!ntable.IsMongoDb);
            if (!ndt.Columns.Contains(columnName)) { tool.ExecResult = $"No column '{columnName}' found in table '{tableName}'."; return; }
            var seen     = new System.Collections.Generic.HashSet<string>();
            var distinct = new System.Collections.Generic.List<string>();
            foreach (System.Data.DataRow row in ndt.Rows) {
                var v = row[columnName];
                if (v == DBNull.Value) continue;
                var s = v?.ToString() ?? "";
                if (seen.Add(s)) distinct.Add(s);
            }
            if (distinct.Count == 0) { tool.ExecResult = $"No non-null values found in {tableName}.{columnName}."; return; }
            distinct.Sort();
            var nres = string.Join(", ", distinct.Take(50));
            if (distinct.Count > 50) nres += $" ... ({distinct.Count} distinct values total, first 50 shown)";
            if (ntable.IsMongoDb) nres += " (values observed in a preview of up to 100 documents)";
            tool.ExecResult = nres;
        }
        catch (Exception ex) { tool.ExecResult = $"Error: {ex.Message}"; }
        tool.CurrentToolCall.LogMessage($"Tool '{tool.CurrentToolCall.Name}' finished.");
        return;
    }

    var conn = tool.GetExecConnection(source, connGuid);
    if (conn == null) { tool.ExecResult = "Error: no connection configured."; return; }

    var connection = conn.GetOpenConnection();
    var helper     = new TaskDatabaseHelper();
    try {
        // Resolve against the source metadata when possible: MetaTable.FullSQLName handles
        // aliases and custom SQL tables, and the MetaColumn name is the exact SQL the engine
        // generates. Otherwise fall back to GetTableName/GetColumnName, which apply the
        // database-type delimiters only when the raw name requires them.
        string tableSQL, columnSQL;
        var mtable = source.MetaData.Tables.FirstOrDefault(t => t.Name == tableName || t.DisplayName == tableName || t.Alias == tableName);
        var mcol   = mtable == null ? null : mtable.Columns.FirstOrDefault(c => c.Name == columnName || c.Name.EndsWith("." + columnName) || c.DisplayName == columnName);
        if (mtable != null && mcol != null) { tableSQL = mtable.FullSQLName; columnSQL = mcol.Name; }
        else { tableSQL = source.GetTableName(tableName); columnSQL = source.GetColumnName(columnName); }
        var sql = $"SELECT DISTINCT {columnSQL} FROM {tableSQL} " +
                  $"WHERE {columnSQL} IS NOT NULL ORDER BY {columnSQL}";
        var table = helper.LoadDataTable(conn.ConnectionType,
                                         conn.FullConnectionString,
                                         sql, connection);
        if (table.Rows.Count == 0) {
            tool.ExecResult = $"No non-null values found in {tableName}.{columnName}.";
            return;
        }

        var values = new List<string>();
        int cnt = 0;
        foreach (System.Data.DataRow row in table.Rows) {
            if (++cnt > 50) break;
            values.Add(row[0]?.ToString() ?? "");
        }
        var result = string.Join(", ", values);
        if (table.Rows.Count > 50)
            result += $" ... ({table.Rows.Count} distinct values total, first 50 shown)";
        tool.ExecResult = result;
    }
    catch (Exception ex) { tool.ExecResult = $"Error: {ex.Message}"; }
    finally               { connection.Close(); }
    tool.CurrentToolCall.LogMessage($"Tool '{tool.CurrentToolCall.Name}' finished.");
}
