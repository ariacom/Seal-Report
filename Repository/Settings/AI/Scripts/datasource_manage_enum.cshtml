@using System.IO
@using System.Linq
@using System.Text
@using System.Text.Json
@using Seal.Model
@using Seal.AI
@{
    AIToolConfiguration tool = Model;
    var securityContext = tool.CurrentToolCall.SecurityContext;
    if (securityContext == null) { tool.ExecResult = "Error: no security context available."; return; }

    var args     = JsonDocument.Parse(tool.CurrentToolCall.Arguments).RootElement;
    var dsGuid   = args.TryGetProperty("datasource_guid", out var dsp) ? dsp.GetString() : null;
    var action   = args.TryGetProperty("action", out var acp) ? acp.GetString() : "add";
    var name     = args.TryGetProperty("name", out var nmp) ? nmp.GetString() : null;
    var colGuid  = args.TryGetProperty("column_guid", out var cgp) ? cgp.GetString() : null;
    var assignTo = args.TryGetProperty("assign_to_column_guid", out var atp) ? atp.GetString() : null;
    tool.CurrentToolCall.LogMessage($"Starting tool '{tool.CurrentToolCall.Name}' (action: {action})..");

    var source = !string.IsNullOrEmpty(dsGuid)
        ? tool.GetAvailableSources().FirstOrDefault(s => s.GUID == dsGuid)
        : tool.GetExecSource(null);
    if (source == null) { tool.ExecResult = "Error: data source not found or not allowed."; return; }
    var srcDir = Path.GetDirectoryName(source.FilePath);
    if (string.IsNullOrEmpty(srcDir) || !securityContext.HasFolderRight(srcDir, (int)FolderRight.Edit))
    { tool.ExecResult = "Error: editing data sources requires write (Edit) access to the source's folder, published via the group's Repository Folders. It is not enabled for your security group."; return; }

    Func<string, MetaColumn> findCol = g => source.MetaData.Tables.SelectMany(t => t.Columns)
        .FirstOrDefault(c => string.Equals(c.GUID, g, StringComparison.OrdinalIgnoreCase));

    Func<MetaSource, string> backup = s => {
        if (!string.IsNullOrEmpty(s.FilePath) && File.Exists(s.FilePath)) {
            var b = s.FilePath + ".bak-" + DateTime.Now.ToString("yyyyMMddHHmmss");
            File.Copy(s.FilePath, b, true); return Path.GetFileName(b);
        }
        return "(none)";
    };

    try
    {
        MetaEnum e;
        if (string.Equals(action, "create_from_column", StringComparison.OrdinalIgnoreCase))
        {
            var col = findCol(colGuid);
            if (col == null) { tool.ExecResult = "Error: column_guid not found; required for create_from_column."; return; }
            e = source.CreateEnumFromColumn(col);
            if (!string.IsNullOrEmpty(name)) e.Name = name;
        }
        else
        {
            e = source.AddEnum();
            if (!string.IsNullOrEmpty(name)) e.Name = name;
            if (args.TryGetProperty("values", out var vals) && vals.ValueKind == JsonValueKind.Array)
            {
                foreach (var v in vals.EnumerateArray())
                {
                    var id = v.GetString();
                    if (!string.IsNullOrEmpty(id) && !e.Values.Any(x => x.Id == id))
                        e.Values.Add(new MetaEV() { Id = id, Val = id });
                }
            }
            e.RefreshEnum();
        }

        string assignMsg = "";
        if (!string.IsNullOrEmpty(assignTo))
        {
            var target = findCol(assignTo);
            if (target == null) { source.RemoveEnum(e); tool.ExecResult = "Error: assign_to_column_guid not found."; return; }
            target.EnumGUID = e.GUID;
            assignMsg = $" Assigned to column '{target.Name}'.";
        }

        source.LastMetadataModification = DateTime.Now;
        var bak = backup(source);
        source.SaveToFile();
        tool.ExecResult = $"Enum '{e.Name}' ready (GUID: {e.GUID}, {e.Values.Count} value(s), dynamic: {e.IsDynamic}).{assignMsg} Backup: {bak}";
    }
    catch (Exception ex) { tool.ExecResult = $"Error: {ex.Message}"; }
    tool.CurrentToolCall.LogMessage($"Tool '{tool.CurrentToolCall.Name}' finished.");
}
