  <GUID>297385b3-45fa-4199-ae7e-b7c5c2b1b275</GUID>
  <DisplayName>Top 10 Best Suppliers in 1997 in Amount</DisplayName>
  <ViewGUID>6866467a-afca-4e9a-a9f4-c7803c71d054</ViewGUID>
  <Sources>
    <ReportSource>
      <GUID>32b755a8-0c62-4f67-a051-ca010a54cc40</GUID>
