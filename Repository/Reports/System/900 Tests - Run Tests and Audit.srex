          <Name>sr_test_results.warnings</Name>
          <DisplayName />
          <PivotPosition>Row</PivotPosition>
          <MetaColumnGUID>7e57ab1e-0000-4000-8000-000000000111</MetaColumnGUID>
          <CellScript>@{
    //Render line breaks (CR/LF) in the warnings text as HTML so multiple warnings display on several lines.
    ResultCell cell = Model;
    if (!cell.IsTitle &amp;&amp; cell.Value != null) {
