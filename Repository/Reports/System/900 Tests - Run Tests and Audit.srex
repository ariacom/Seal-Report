</CellScript>
          <ContainsHtml>true</ContainsHtml>
        </ReportElement>
        <ReportElement>
          <GUID>a9000000-0000-4000-8000-000000000317</GUID>
          <Name>sr_test_results.messages_file</Name>
          <DisplayName>Messages</DisplayName>
          <CssStyle>text-align:center</CssStyle>
          <PivotPosition>Row</PivotPosition>
          <MetaColumnGUID>7e57ab1e-0000-4000-8000-000000000108</MetaColumnGUID>
          <CellScript>@{
    //Turn the messages file cell into a 'View' link opening the execution messages HTML file.
    //Web Server: open the file in a new browser tab through the 'SWViewFile' endpoint. 'messages_file' is stored
    //as a path relative to the repository 'Reports' folder, which is exactly what 'SWViewFile?path=' expects.
    //Desktop Report Viewer (no WebUrl): keep a file download navigation; the path is resolved by the
    //'Navigation Script' of this element and the file is opened by the viewer.
    //'FinalValue' only changes what is displayed; 'cell.Value' still holds the path used to build the link.
    ResultCell cell = Model;
    if (!cell.IsTitle &amp;&amp; cell.Value != null &amp;&amp; !string.IsNullOrEmpty(cell.Value.ToString())) {
        Report report = cell.ContextModel.Report;
        if (!string.IsNullOrEmpty(report.WebUrl)) {
            cell.AddNavigationHyperLink(report.WebUrl + "SWViewFile?path=" + System.Net.WebUtility.UrlEncode(cell.Value.ToString()), "View messages");
        }
        else {
            cell.AddNavigationFileDownload("View messages");
        }
        cell.FinalValue = "&lt;span class='fa-solid fa-rectangle-list' title='View messages'&gt;&lt;/span&gt;";
    }
}
</CellScript>
          <NavigationScript>@using System.IO
@{
    //'messages_file' stores a path relative to the repository 'Reports' folder.
    //Resolve it to a full path so the HTML file can be downloaded/opened.
    NavigationLink link = Model;
    ResultCell cell = link.Cell;
    Report report = cell.ContextModel.Report;

    var relativePath = cell.Value == null ? "" : cell.Value.ToString();
    if (!string.IsNullOrEmpty(relativePath)) {
        link.ScriptResult = Path.Combine(report.Repository.ReportsFolder, relativePath.TrimStart('\\', '/'));
    }
}
</NavigationScript>
          <CssStyleEl>text-align:center</CssStyleEl>
