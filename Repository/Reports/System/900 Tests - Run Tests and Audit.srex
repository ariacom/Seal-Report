  <InitScript>@using System.IO
@{
    Report report = Model;
    var source = report.Sources.FirstOrDefault();
    var list = source == null ? null : source.MetaData.Enums.FirstOrDefault(i =&gt; i.Name == "Test Reports");
    if (list != null) {
        list.Values.Clear();
        var folder = Path.Combine(report.Repository.ReportsFolder, "System\\Tests");
        if (Directory.Exists(folder)) {
            foreach (var file in Directory.GetFiles(folder, "*.srex").Where(i =&gt; !Path.GetFileName(i).StartsWith("~")).OrderBy(i =&gt; i)) {
                list.Values.Add(new MetaEV() { Id = Path.GetFileName(file), Val = Path.GetFileNameWithoutExtension(file) });
            }
        }
    }
}
</InitScript>
  <Cancel>false</Cancel>
</Report>