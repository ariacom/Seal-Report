          <CellScript>@{
    //Render line breaks (CR/LF) in the error text as HTML so multi-line errors display on several lines.
    ResultCell cell = Model;
    if (!cell.IsTitle &amp;&amp; cell.Value != null) {
        var s = cell.Value.ToString();
        if (!string.IsNullOrEmpty(s)) cell.FinalValue = System.Net.WebUtility.HtmlEncode(s).Replace("\r\n", "&lt;br&gt;").Replace("\n", "&lt;br&gt;");
    }
}
</CellScript>
