  <Tasks>
    <ReportTask>
      <GUID>b7920b46-bf3e-4202-ad4d-9bea5530b654</GUID>
      <Name>Default</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>6bf3797e-be9e-464a-9d67-7298215b133b</SourceGUID>
      <Script>@using System.Security.Cryptography;
@using System.IO;
@{
    ReportTask task = Model;
    Report report = task.Report;
    
    var cmdShell = "\r\n";
    foreach (var key in report.Repository.Configuration.KeyValues) {
        CspParameters csp = new CspParameters();
        csp.KeyContainerName = key.Name;
        csp.Flags = CspProviderFlags.UseMachineKeyStore;
        RSACryptoServiceProvider rsa = new RSACryptoServiceProvider(csp);
        task.LogMessage(rsa.CspKeyContainerInfo.KeyContainerName + " " + rsa.CspKeyContainerInfo.UniqueKeyContainerName);
        //Power shell to add rights
        cmdShell += $@"&amp; ""C:\Windows\Microsoft.NET\Framework64\v4.0.30319\aspnet_regiis.exe"" -pa ""{rsa.CspKeyContainerInfo.UniqueKeyContainerName}"" ""adbames\s-ereports""" + "\r\n";        
    }
    task.LogMessage(cmdShell);
        
    task.LogMessage("Key=" + report.Repository.GetApplicationKey("demo user password"));
    task.LogMessage("Pwd=" + report.Repository.Configuration.ClearSchedulerPassword);
    task.LogMessage("Pwd=" + report.Sources.First(i =&gt; i.Name.StartsWith("ER APSYS Oracle")).Connection.ClearPassword);
}
</Script>
      <SortOrder>1</SortOrder>
    </ReportTask>
  </Tasks>
