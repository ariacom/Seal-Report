            <DefinitionScript>@using System.Data
@{
	MetaTable metaTable = Model;
	metaTable.NoSQLTable = new DataTable();
	metaTable.NoSQLTable.Columns.Add(new DataColumn("source", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("source_description", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("connection_name", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("connection_type", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("database_type", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("connection_description", typeof(string)));

	metaTable.LogMessage("{0} column(s) defined", metaTable.NoSQLTable.Columns.Count);
}
</DefinitionScript>
            <LoadScript>@using System.Data

@{
	MetaTable metaTable = Model;
	DataTable table = metaTable.NoSQLTable;
	ReportExecutionLog log = metaTable;
	ReportModel reportModel = metaTable.NoSQLModel;

	foreach (var metaSource in Repository.Instance.Sources)
    {
        if (metaSource.Connections.Count == 0)
        {
            table.Rows.Add(metaSource.Name, metaSource.Description ?? "", "", "", "", "");
        }
        foreach (var connection in metaSource.Connections)
        {
            table.Rows.Add(metaSource.Name, metaSource.Description ?? "", connection.Name, connection.ConnectionType.ToString(), connection.DatabaseType.ToString(), connection.Description ?? "");
        }
    }
	log.LogMessage("{0} record(s) loaded", table.Rows.Count);
}
</LoadScript>
