            <DefinitionScript>@using System.Data
@{
	MetaTable metaTable = Model;
	metaTable.NoSQLTable = new DataTable();
	metaTable.NoSQLTable.Columns.Add(new DataColumn("source", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("join_name", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("left_table", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("right_table", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("join_type", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("clause", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("description", typeof(string)));

	metaTable.LogMessage("{0} column(s) defined", metaTable.NoSQLTable.Columns.Count);
}
</DefinitionScript>
            <LoadScript>@using System.Data

@{
	MetaTable metaTable = Model;
	DataTable table = metaTable.NoSQLTable;
	ReportExecutionLog log = metaTable;
	ReportModel reportModel = metaTable.NoSQLModel;

	foreach (var metaSource in Repository.Instance.Sources)
    {
        foreach (var join in metaSource.MetaData.Joins)
        {
            table.Rows.Add(metaSource.Name, join.Name ?? "", join.LeftTable != null ? join.LeftTable.AliasName : "", join.RightTable != null ? join.RightTable.AliasName : "", join.JoinType.ToString(), join.Clause, join.Description ?? "");
        }
    }
	log.LogMessage("{0} record(s) loaded", table.Rows.Count);
}
</LoadScript>
