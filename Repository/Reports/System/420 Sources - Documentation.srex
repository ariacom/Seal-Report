            <DefinitionScript>@using System.Data
@{
	MetaTable metaTable = Model;
	metaTable.NoSQLTable = new DataTable();
	metaTable.NoSQLTable.Columns.Add(new DataColumn("source", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("table_name", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("alias", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("table_type", typeof(string)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("column_count", typeof(int)));
	metaTable.NoSQLTable.Columns.Add(new DataColumn("description", typeof(string)));

	metaTable.LogMessage("{0} column(s) defined", metaTable.NoSQLTable.Columns.Count);
