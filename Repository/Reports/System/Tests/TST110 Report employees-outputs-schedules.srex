          <SourceGUID>6498451a-db9b-41ae-b8ee-97261e254581</SourceGUID>
          <Script>@using Seal.AI;
@using System.IO;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var ctx = (Dictionary&lt;string, object&gt;)task.ExecInput;
    if (ctx.ContainsKey("Error")) return;
    var outputDir = (string)ctx["OutputDir"];
    var providerName = (string)ctx["ProviderName"];
    var assistants = (Dictionary&lt;string, AIAssistantConfiguration&gt;)ctx["Assistants"];

    try
    {
        task.LogMessage($"[{providerName}] Executing '{task.Name}'");

        var assistant = new AIAssistant(assistants["Schedule &amp; Output"]);
        assistant.SecurityContext = report.SecurityContext;

        var request = @$"List all reports in directory {outputDir}, for each report, remove all existing schedules";
        task.LogMessage(request);
        assistant.Chat(request, cancelOperation: report, log: report, toolsLog: report);
        if (report.Cancel) return;

        assistant = new AIAssistant(assistants["System Admin"]);
        assistant.SecurityContext = report.SecurityContext;
        request = @$"Delete all reports and files stored in directory {outputDir}";
        task.LogMessage(request);
        assistant.Chat(request, cancelOperation: report, log: report, toolsLog: report);
        if (report.Cancel) return;

        //Check
        if (Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir)).Length &gt; 0) throw new Exception($"Files still exist in '{outputDir}' after the assistant call.");
    }
    catch (Exception ex) { ctx["Error"] = $"[{task.Name}] {ex.Message}"; }
}
</Script>
          <SortOrder>1</SortOrder>
        </ReportTask>
        <ReportTask>
          <GUID>d7edafe8-8536-4e34-a228-309d200d7a33</GUID>
          <Name>Create report</Name>
          <Tasks />
          <ExecProcessChildren>true</ExecProcessChildren>
          <TemplateName>Default</TemplateName>
          <SourceGUID>6498451a-db9b-41ae-b8ee-97261e254581</SourceGUID>
          <Script>@using Seal.AI;
@using System.IO;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var ctx = (Dictionary&lt;string, object&gt;)task.ExecInput;
    if (ctx.ContainsKey("Error")) return;
    var outputDir = (string)ctx["OutputDir"];
    var providerName = (string)ctx["ProviderName"];
    var assistants = (Dictionary&lt;string, AIAssistantConfiguration&gt;)ctx["Assistants"];

    try
    {
        task.LogMessage($"[{providerName}] Executing '{task.Name}'");

        var assistant = new AIAssistant(assistants["Report Designer"]);
        assistant.SecurityContext = report.SecurityContext;

        var request = $@"
        Create a report named 'List of employees.srex' in directory {outputDir} using the Northwind data source.
        The report model must list the employees with EXACTLY these five Row dimension elements, in this order:
          - 'Last Name' (Employees.LastName)
          - 'First Name' (Employees.FirstName)
          - 'Title' (Employees.Title)
          - 'City' (Employees.City)
          - 'Country' (Employees.Country)
        Sort the rows by Last Name ASCENDING. Do NOT aggregate any element, do NOT add a Data element, and do NOT add any restriction.
        Each employee must appear exactly once (one row per employee).
    ";
        task.LogMessage(request);
        assistant.Chat(request, cancelOperation: report, log: report, toolsLog: report);
        if (report.Cancel) return;

        //Check report created and get its file path
        var reportFiles = Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir), "*.srex");
        if (reportFiles.Length == 0) throw new Exception($"Report was not created in '{outputDir}' after the assistant call.");
        var reportFilePath = reportFiles[0];

        request = $@"
        Get the data of the report located at '{reportFilePath}'.
        Check 1: the table has EXACTLY 9 employee rows.
        Check 2: the set of values in the 'Last Name' column is EXACTLY this set of 9 names, regardless of order:
          Buchanan, Callahan, Davolio, Dodsworth, Fuller, King, Leverling, Peacock, Suyama.
        Order does NOT matter; only the row count and the set of last names matter.
        If both checks succeed, answer with exactly 'CHECK OK'.
        If any check fails, answer with exactly 'CHECK FAILED' followed by the reason.
    ";
        task.LogMessage(request);
        var checkResult = assistant.Chat(request, cancelOperation: report, log: report, toolsLog: report);
        if (report.Cancel) return;

        if (checkResult == null || !checkResult.ToString().Contains("CHECK OK"))
            throw new Exception($"Data check failed for '{reportFilePath}': {checkResult}");
    }
    catch (Exception ex) { ctx["Error"] = $"[{task.Name}] {ex.Message}"; }
}
</Script>
          <SortOrder>2</SortOrder>
        </ReportTask>
        <ReportTask>
          <GUID>c93aed60-171f-460f-acf1-acd1ca0fe01b</GUID>
          <Name>Outputs and schedules</Name>
          <Tasks />
          <ExecProcessChildren>true</ExecProcessChildren>
          <TemplateName>Default</TemplateName>
          <SourceGUID>6498451a-db9b-41ae-b8ee-97261e254581</SourceGUID>
          <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var ctx = (Dictionary&lt;string, object&gt;)task.ExecInput;
    if (ctx.ContainsKey("Error")) return;
    var outputDir = (string)ctx["OutputDir"];
    var providerName = (string)ctx["ProviderName"];
    var assistants = (Dictionary&lt;string, AIAssistantConfiguration&gt;)ctx["Assistants"];

    try
    {
        task.LogMessage($"[{providerName}] Executing '{task.Name}'");

        var assistant = new AIAssistant(assistants["Schedule &amp; Output"]);
        assistant.SecurityContext = report.SecurityContext;

        var reportFiles = Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir), "*.srex");
        if (reportFiles.Length == 0) throw new Exception($"Report was not created in '{outputDir}' after the assistant call.");
        var reportFilePath = reportFiles[0];

        //==================== STEP 1: create 4 outputs (Email x1, FTP x1, Folder x2) ====================
        var request = $@"
        For the report located at '{reportFilePath}', create EXACTLY four outputs:
          - ONE output named 'Email' using the device named 'Email Device' for user test@testemail.com, format Excel.
          - ONE output named 'FTP' using the device named 'FTP Device', format PDF.
          - ONE output named 'PDF' using the default Folder device, generating the normal file name in {outputDir}, format PDF.
          - ONE output named 'Excel' using the default Folder device, generating the file name with a daily date in {outputDir}, format Excel.
        Do NOT create any schedule at this step.
    ";
        task.LogMessage(request);
        assistant.Chat(request, cancelOperation: report, log: report, toolsLog: report);
        if (report.Cancel) return;

        //Check: 1 Email + 1 FTP + 2 Folder = 4 outputs
        var r = Report.LoadFromFile(reportFilePath, repository);
        var emailCount = r.Outputs.Count(o =&gt; o.Device is OutputEmailDevice);
        var ftpCount = r.Outputs.Count(o =&gt; o.Device is OutputFileServerDevice);
        var folderCount = r.Outputs.Count(o =&gt; o.Device is OutputFolderDevice);
        if (r.Outputs.Count != 4) throw new Exception($"STEP1 expected 4 outputs, found {r.Outputs.Count}.");
        if (emailCount != 1) throw new Exception($"STEP1 expected 1 Email output, found {emailCount}.");
        if (ftpCount != 1) throw new Exception($"STEP1 expected 1 FTP output, found {ftpCount}.");
        if (folderCount != 2) throw new Exception($"STEP1 expected 2 Folder outputs, found {folderCount}.");

        //==================== STEP 2: remove ONE Folder output ====================
        request = $@"
        For the report located at '{reportFilePath}', remove the output name 'PDF'. Keep the other Folder output and do not touch the Email or FTP outputs.
    ";
        task.LogMessage(request);
        assistant.Chat(request, cancelOperation: report, log: report, toolsLog: report);
        if (report.Cancel) return;

        //Check: 1 Email + 1 FTP + 1 Folder = 3 outputs
        r = Report.LoadFromFile(reportFilePath, repository);
        emailCount = r.Outputs.Count(o =&gt; o.Device is OutputEmailDevice);
        ftpCount = r.Outputs.Count(o =&gt; o.Device is OutputFileServerDevice);
        folderCount = r.Outputs.Count(o =&gt; o.Device is OutputFolderDevice);
        if (r.Outputs.Count != 3) throw new Exception($"STEP2 expected 3 outputs, found {r.Outputs.Count}.");
        if (folderCount != 1) throw new Exception($"STEP2 expected 1 Folder output, found {folderCount}.");
        if (emailCount != 1 || ftpCount != 1) throw new Exception($"STEP2 expected Email=1/FTP=1, found Email={emailCount}/FTP={ftpCount}.");

        //==================== STEP 3: create 2 schedules on the FTP output ====================
        request = $@"
        For the report located at '{reportFilePath}', create TWO schedules on the output that uses the 'FTP Device'.
        Schedule the first one every Monday at 10:45 and the second one every second day of the month at 11:45.
    ";
        task.LogMessage(request);
        assistant.Chat(request, cancelOperation: report, log: report, toolsLog: report);
        if (report.Cancel) return;

        //Check: 2 schedules attached to the FTP output
        r = Report.LoadFromFile(reportFilePath, repository);
        var ftpSchedules = r.Schedules.Count(s =&gt; s.Output != null &amp;&amp; s.Output.Device is OutputFileServerDevice);
        if (ftpSchedules != 2) throw new Exception($"STEP3 expected 2 FTP schedules, found {ftpSchedules}.");

        //==================== STEP 4: remove ONE FTP schedule ====================
        request = $@"
        For the report located at '{reportFilePath}', remove EXACTLY ONE of the two schedules attached to the 'FTP Device' output. Keep the other one.
    ";
        task.LogMessage(request);
        assistant.Chat(request, cancelOperation: report, log: report, toolsLog: report);
        if (report.Cancel) return;

        //Check: 1 schedule attached to the FTP output
        r = Report.LoadFromFile(reportFilePath, repository);
        ftpSchedules = r.Schedules.Count(s =&gt; s.Output != null &amp;&amp; s.Output.Device is OutputFileServerDevice);
        if (ftpSchedules != 1) throw new Exception($"STEP4 expected 1 FTP schedule, found {ftpSchedules}.");
    }
    catch (Exception ex) { ctx["Error"] = $"[{task.Name}] {ex.Message}"; }
}
</Script>
          <SortOrder>3</SortOrder>
