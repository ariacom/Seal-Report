              <GUID>b1a7c010-0020-4a00-9000-000000000503</GUID>
              <Name>Container</Name>
              <Views>
                <ReportView>
                  <GUID>b1a7c010-0020-4a00-9000-000000000504</GUID>
                  <Name>Page Table</Name>
                  <TemplateName>Page Table</TemplateName>
                  <SortOrder>1</SortOrder>
                </ReportView>
                <ReportView>
                  <GUID>b1a7c010-0020-4a00-9000-000000000505</GUID>
                  <Name>Data Table</Name>
