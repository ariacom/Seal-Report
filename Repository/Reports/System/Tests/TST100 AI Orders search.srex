      <SourceGUID>7a1b2c3d-4e5f-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;

    //Base output directory (subfolder = 6 first chars of the report name)
    var subDir = Path.GetFileNameWithoutExtension(report.FilePath).Substring(0, 6);
    var baseDir = $@"Reports\System\Tests\Output\{subDir}";

    //Single provider to test = the one selected in 'Provider to test', else the first enabled provider
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    if (enabled.Count == 0) throw new Exception("No enabled AI provider found to test.");
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();

    //Dedicated output sub-folder for this provider (read by the next tasks from report.StringTag)
    var safeName = string.Join("_", provider.Name.Split(Path.GetInvalidFileNameChars()));
    var outputDir = Path.Combine(baseDir, safeName);
    Directory.CreateDirectory(Path.Combine(repository.RepositoryPath, outputDir));
    report.StringTag = outputDir;

    //Default result (overwritten with the match rate by 'Check Pattern'); read by '900 Tests' from report.ResultTag
    report.ResultTag = new object[] { provider.Name, 0.0, "Error", null };

    //Security context with write access to the output folder
    var user = new SecurityUser(repository.Security);
    user.AddSecurityGroup("Group System Tests");
    user.SetFolders();
    report.SecurityContext = user;

    task.LogMessage($"Testing provider '{provider.Name}' -&gt; {outputDir}");
}
</Script>
      <SortOrder>2</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>2c8b9d6e-5f4a-4b3c-9d2e-9f8a7b6c5d4e</GUID>
      <Name>Cleanup</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>7a1b2c3d-4e5f-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@using System.IO;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var outputDir = report.StringTag;

    try
    {
        task.LogMessage($"Executing '{task.Name}'");
        var dir = Path.Combine(repository.RepositoryPath, outputDir);
        if (Directory.Exists(dir))
            foreach (var f in Directory.GetFiles(dir)) File.Delete(f);
    }
    catch (Exception ex)
    {
        var pr = report.ResultTag as object[];
        var pn = pr != null ? (string)pr[0] : null;
        report.ResultTag = new object[] { pn, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
      <SortOrder>3</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>3d7c8e5f-4a6b-4c2d-9e1f-8a7b6c5d4e3f</GUID>
      <Name>Create report</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>7a1b2c3d-4e5f-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    var agentConfig = (AIAgentConfiguration)Helper.Clone(config.AIAgents.First(a =&gt; a.Name == "Report Designer"));
    agentConfig.ProviderGUID = provider.GUID;
    var agent = new AIAgent(agentConfig);
    agent.SecurityContext = report.SecurityContext;

        var request = $@"
        Create a report named 'Orders search.srex' in directory {outputDir} using the Northwind data source.
        Build a DETAIL (flat list) report model - NOT a cross tab. The model must have NO column dimension and NO page dimension.
        Add EXACTLY these six ROW elements (one displayed column each, in this order):
          - 'Order Date' (Orders.OrderDate).
          - 'Order ID' (Orders.OrderID).
          - 'Customer' (Customers.CompanyName).
          - 'Customer Country' (Customers.Country).
          - 'Customer Contact' (Customers.ContactName).
          - 'Shipper' (Shippers.CompanyName, the shipping company).
        Add EXACTLY these three DATA elements (numeric measures), each aggregated with Sum and showing a column total:
          - 'Amount' ((1-[Order Details].Discount)*[Order Details].Quantity*[Order Details].UnitPrice) - the net sales amount.
          - 'Discount' ([Order Details].Discount*[Order Details].Quantity*[Order Details].UnitPrice) - the discounted amount.
          - 'Quantity' ([Order Details].Quantity) - the number of units ordered.
        Add EXACTLY these six RESTRICTIONS and set EVERY one of them to be PROMPTED at execution:
          - 'Order Date' (Orders.OrderDate), Between operator, prompting two values (from / to), with a default keeping the whole year 1997 (between 1997-01-01 and 1997-12-31).
          - 'Customer' (Customers.CompanyName), with the 'Contains' operator (free text filter).
          - 'Customer Country' (Customers.Country).
          - 'Customer Contact' (Customers.ContactName), with the 'Contains' operator (free text filter).
          - 'Shipper' (Shippers.CompanyName), with the 'Contains' operator (free text filter).
          - 'Order ID' (Orders.OrderID).
        These six are RESTRICTIONS and must all be prompted at execution. 'Customer', 'Customer Country', 'Customer Contact', 'Shipper' and 'Order ID' are each BOTH a row element AND a prompted restriction.
        Do not add any chart serie and do not add a column or page dimension: this is a plain detail list, keep the default table view.
        Force the report execution using the current restrictions.
    ";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Check report created and get its file path
        var reportFiles = Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir), "*.srex");
        if (reportFiles.Length == 0) throw new Exception($"Report was not created in '{outputDir}' after the agent call.");
        var reportFilePath = reportFiles[0];

        //Structural checks on the created report
        var r = Report.LoadFromFile(reportFilePath, repository);
        var model = r.Models.FirstOrDefault();
        if (model == null) throw new Exception("No model found in the created report.");

        var rows = model.GetElements(PivotPosition.Row).ToList();
        var cols = model.GetElements(PivotPosition.Column).ToList();
        var datas = model.GetElements(PivotPosition.Data).ToList();

        //Detail list: there must be NO column (and no page) dimension
        if (cols.Count != 0)
            throw new Exception($"Expected a flat detail list with no Column element, found {cols.Count} ({string.Join(", ", cols.Select(e =&gt; e.MetaColumn?.DisplayName))}).");

        //Expected row elements are all present
        foreach (var disp in new[] { "Order Date", "Order ID", "Customer", "Customer Country", "Customer Contact", "Shipper" })
        {
            if (!rows.Any(e =&gt; e.MetaColumn != null &amp;&amp; e.MetaColumn.DisplayName == disp))
                throw new Exception($"Missing Row element '{disp}'. Found rows: {string.Join(", ", rows.Select(e =&gt; e.MetaColumn?.DisplayName))}.");
        }

        //Expected data measures, each aggregated with Sum
        foreach (var disp in new[] { "Amount", "Discount", "Quantity" })
        {
            var d = datas.FirstOrDefault(e =&gt; e.MetaColumn != null &amp;&amp; e.MetaColumn.DisplayName == disp);
            if (d == null) throw new Exception($"Missing Data element '{disp}'. Found datas: {string.Join(", ", datas.Select(e =&gt; e.MetaColumn?.DisplayName))}.");
            if (d.AggregateFunction != AggregateFunction.Sum)
                throw new Exception($"Data element '{disp}' must be aggregated with Sum, found {d.AggregateFunction}.");
        }

        //Restriction checks: the six expected restrictions, all prompted, on the expected columns
        var prompted = model.Restrictions.Where(x =&gt; x.Prompt != PromptType.None).ToList();
        foreach (var disp in new[] { "Order Date", "Customer", "Customer Country", "Customer Contact", "Shipper", "Order ID" })
        {
            if (!prompted.Any(x =&gt; x.MetaColumn != null &amp;&amp; x.MetaColumn.DisplayName == disp))
                throw new Exception($"Missing prompted restriction on '{disp}'.");
        }
}
</Script>
      <SortOrder>4</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>4e6d9f4a-3b7c-4d1e-8f2a-7b6c5d4e3f2a</GUID>
      <Name>Check Pattern</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>7a1b2c3d-4e5f-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@using Seal.Model;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var outputDir = report.StringTag;
    var providerName = (report.ResultTag as object[])?[0] as string;

    task.LogMessage($"Executing '{task.Name}'");

        //Generic Check Pattern: pair every generated report with the expected (pattern) report and compare their definition.
        //Pattern directory = Reports\System\Tests\Pattern\&lt;6 first chars of the report name&gt; (e.g. 'TST100').
        var subDir = Path.GetFileNameWithoutExtension(report.FilePath).Substring(0, 6);
        var patternDir = Path.Combine(repository.RepositoryPath, "Reports", "System", "Tests", "Pattern", subDir);
        if (!Directory.Exists(patternDir)) throw new Exception($"Pattern directory not found: '{patternDir}'.");

        var generatedFiles = Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir), "*.srex");
        if (generatedFiles.Length == 0) throw new Exception($"No generated report found in '{outputDir}'.");
        var patternFiles = Directory.GetFiles(patternDir, "*.srex");
        if (patternFiles.Length == 0) throw new Exception($"No pattern report found in '{patternDir}'.");

        var failures = new List&lt;string&gt;();
        var warnings = new List&lt;string&gt;();
        var scores = new List&lt;double&gt;();
        foreach (var generatedFile in generatedFiles)
        {
            var key = Normalize(Path.GetFileNameWithoutExtension(generatedFile));
            var patternFile = patternFiles.FirstOrDefault(p =&gt; Normalize(Path.GetFileNameWithoutExtension(p)) == key);
            if (patternFile == null &amp;&amp; generatedFiles.Length == 1 &amp;&amp; patternFiles.Length == 1) patternFile = patternFiles[0];
            if (patternFile == null) throw new Exception($"No pattern report matching '{Path.GetFileName(generatedFile)}' found in '{patternDir}'.");

            var expected = Report.LoadFromFile(patternFile, repository);
            var generated = Report.LoadFromFile(generatedFile, repository);

            var result = CheckPattern(expected, generated);
            scores.Add(result.Score);

            task.LogMessage($"Check Pattern '{Path.GetFileName(generatedFile)}' vs '{Path.GetFileName(patternFile)}': {result.Status} ({result.Score}%)");
            foreach (var m in result.Messages) task.LogMessage("  - " + m);

            //Only FAILURE fails the test; WARNING is reported but does not cause an error.
            if (result.Status == "FAILURE")
                failures.Add($"{Path.GetFileName(generatedFile)}: FAILURE ({result.Score}%) - {string.Join("; ", result.Messages)}");

            //Collect WARNING messages (typically raised when the match rate is below 100% without a structural failure)
            foreach (var m in result.Messages.Where(i =&gt; i.StartsWith("WARNING:")))
                warnings.Add($"{Path.GetFileName(generatedFile)}: {m}");
        }

        //Average pattern-match score across the generated report(s) = this provider's match rate (%)
        var rate = scores.Count &gt; 0 ? Math.Round(scores.Average(), 1) : 0.0;
        //Warning messages recorded by '900 Tests' (sr_test_results.warnings) - null when the report matches exactly
        var warningText = warnings.Count &gt; 0 ? string.Join(Environment.NewLine, warnings) : null;

        if (failures.Count &gt; 0)
        {
            //Record the failed result for '900 Tests' (report.ResultTag), then fail the report
            report.ResultTag = new object[] { providerName, rate, "Error", string.Join(Environment.NewLine, failures), warningText };
            throw new Exception(string.Join(Environment.NewLine, failures));
        }

        //Record the provider match rate for the test runner ('900 Tests' reads report.ResultTag)
        report.ResultTag = new object[] { providerName, rate, "Success", null, warningText };
}

@functions {
    //Result of a pattern check between an expected (stored pattern) and a generated report.
    public class PatternCheckResult
    {
        public string Status = "OK";   //OK, WARNING or FAILURE
        public double Score = 100;     //100 = exact match
        public List&lt;string&gt; Messages = new List&lt;string&gt;();
    }

    //Compare two reports. 'expected' is the pattern, 'generated' is the produced report.
    //OK = exact match, WARNING = an expected property is missing/differs, FAILURE = model definition incorrect / report not well structured.
    PatternCheckResult CheckPattern(Report expected, Report generated)
    {
        var res = new PatternCheckResult();
        int total = 0, passed = 0;
        bool fail = false, warn = false;

        if (generated == null || !string.IsNullOrEmpty(generated.LoadErrors))
        {
            res.Status = "FAILURE"; res.Score = 0;
            res.Messages.Add($"Generated report is not well structured: {generated?.LoadErrors ?? "report is null"}.");
            return res;
        }

        Check(res, ref total, ref passed, ref fail, ref warn, generated.Models.Count == expected.Models.Count, true,
            $"Model count: expected {expected.Models.Count}, found {generated.Models.Count}.");

        for (int mi = 0; mi &lt; expected.Models.Count; mi++)
        {
            var em = expected.Models[mi];
            var gm = generated.Models.FirstOrDefault(x =&gt; x.Name == em.Name) ?? (mi &lt; generated.Models.Count ? generated.Models[mi] : null);
            if (gm == null) { Check(res, ref total, ref passed, ref fail, ref warn, false, true, $"Model '{em.Name}' is missing."); continue; }

            //Expected elements: presence + pivot position + data aggregate are structural; other properties are WARNING.
            foreach (var ee in em.Elements)
            {
                var k = ElementKey(ee);
                var ge = gm.Elements.FirstOrDefault(x =&gt; ElementKey(x) == k);
                Check(res, ref total, ref passed, ref fail, ref warn, ge != null, true, $"Element '{k}' (expected {ee.PivotPosition}) is missing in model '{em.Name}'.");
                if (ge == null) continue;
                Check(res, ref total, ref passed, ref fail, ref warn, ge.PivotPosition == ee.PivotPosition, true, $"Element '{k}' position: expected {ee.PivotPosition}, found {ge.PivotPosition}.");
                if (ee.PivotPosition == PivotPosition.Data)
                    Check(res, ref total, ref passed, ref fail, ref warn, ge.AggregateFunction == ee.AggregateFunction, true, $"Element '{k}' aggregate: expected {ee.AggregateFunction}, found {ge.AggregateFunction}.");
                Check(res, ref total, ref passed, ref fail, ref warn, ge.SortOrder == ee.SortOrder, false, $"Element '{k}' sort: expected '{ee.SortOrder}', found '{ge.SortOrder}'.");
                Check(res, ref total, ref passed, ref fail, ref warn, (ge.Format ?? "") == (ee.Format ?? ""), false, $"Element '{k}' format: expected '{ee.Format}', found '{ge.Format}'.");
                Check(res, ref total, ref passed, ref fail, ref warn, ge.ShowTotal == ee.ShowTotal, false, $"Element '{k}' total: expected {ee.ShowTotal}, found {ge.ShowTotal}.");
                Check(res, ref total, ref passed, ref fail, ref warn, ge.SerieDefinition == ee.SerieDefinition, false, $"Element '{k}' chart role: expected {ee.SerieDefinition}, found {ge.SerieDefinition}.");
                Check(res, ref total, ref passed, ref fail, ref warn, ge.ChartJSSerie == ee.ChartJSSerie, false, $"Element '{k}' chart serie: expected {ee.ChartJSSerie}, found {ge.ChartJSSerie}.");
            }
            foreach (var ge in gm.Elements.Where(g =&gt; !em.Elements.Any(x =&gt; ElementKey(x) == ElementKey(g))))
                Check(res, ref total, ref passed, ref fail, ref warn, false, false, $"Unexpected element '{ElementKey(ge)}' ({ge.PivotPosition}) in model '{em.Name}'.");

            //Expected restrictions: presence is structural; operator/prompt/default value are WARNING.
            foreach (var er in em.Restrictions)
            {
                var k = RestrictionKey(er);
                var gr = gm.Restrictions.FirstOrDefault(x =&gt; RestrictionKey(x) == k);
                Check(res, ref total, ref passed, ref fail, ref warn, gr != null, true, $"Restriction on '{k}' is missing in model '{em.Name}'.");
                if (gr == null) continue;
                Check(res, ref total, ref passed, ref fail, ref warn, gr.Operator == er.Operator, false, $"Restriction '{k}' operator: expected {er.Operator}, found {gr.Operator}.");
                Check(res, ref total, ref passed, ref fail, ref warn, gr.Prompt == er.Prompt, false, $"Restriction '{k}' prompt: expected {er.Prompt}, found {gr.Prompt}.");
                Check(res, ref total, ref passed, ref fail, ref warn, RestrictionDefault(gr) == RestrictionDefault(er), false, $"Restriction '{k}' default: expected '{RestrictionDefault(er)}', found '{RestrictionDefault(gr)}'.");
            }
            foreach (var gr in gm.Restrictions.Where(g =&gt; !em.Restrictions.Any(x =&gt; RestrictionKey(x) == RestrictionKey(g))))
                Check(res, ref total, ref passed, ref fail, ref warn, false, false, $"Unexpected restriction on '{RestrictionKey(gr)}' in model '{em.Name}'.");
        }

        //Report-level view parameters declared in the pattern (e.g. restrictions_per_row, force_execution): a different/missing value is a WARNING.
        var ev = expected.Views.FirstOrDefault();
        var gv = generated.Views.FirstOrDefault();
        if (ev != null &amp;&amp; gv != null)
        {
            foreach (var ep in ev.Parameters.Where(p =&gt; !string.IsNullOrEmpty(p.Value)))
            {
                var gval = gv.GetValue(ep.Name);
                Check(res, ref total, ref passed, ref fail, ref warn, gval == ep.Value, false,
                    $"Report view parameter '{ep.Name}': expected '{ep.Value}', found '{(string.IsNullOrEmpty(gval) ? "(not set)" : gval)}'.");
            }
        }

        res.Score = total == 0 ? 100 : Math.Round(100.0 * passed / total, 1);
        res.Status = fail ? "FAILURE" : ((warn || res.Score &lt; 100) ? "WARNING" : "OK");
        return res;
    }

    void Check(PatternCheckResult res, ref int total, ref int passed, ref bool fail, ref bool warn, bool ok, bool structural, string message)
    {
        total++;
        if (ok) { passed++; return; }
        if (structural) { fail = true; res.Messages.Add("FAILURE: " + message); }
        else { warn = true; res.Messages.Add("WARNING: " + message); }
    }

    string Normalize(string s) =&gt; new string((s ?? "").ToLowerInvariant().Where(char.IsLetterOrDigit).ToArray());
    string ElementKey(ReportElement e) =&gt; (e.MetaColumn != null ? e.MetaColumn.DisplayName : null) ?? e.Name ?? e.GUID;
    string RestrictionKey(ReportRestriction r) =&gt; (r.MetaColumn != null ? r.MetaColumn.DisplayName : null) ?? r.Name ?? r.GUID;
    string RestrictionDefault(ReportRestriction r) =&gt; $"{r.Operator}|{r.Value1}|{r.Value2}|{r.Date1:yyyy-MM-dd}|{r.Date2:yyyy-MM-dd}";
}
</Script>
      <SortOrder>5</SortOrder>
    </ReportTask>
