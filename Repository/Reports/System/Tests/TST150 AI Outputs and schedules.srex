      <TemplateName>Default</TemplateName>
      <SourceGUID>6498451a-db9b-41ae-b8ee-97261e254581</SourceGUID>
      <Script>@{
    ReportTask task = Model;
    Report report = task.Report;

    //All checks passed: record the success result read by '900 Tests' from report.Tag2
    var pr = report.Tag2 as object[];
    var providerName = pr != null ? (string)pr[0] : null;
    report.Tag2 = new object[] { providerName, null, "Success", null };
    task.LogMessage($"[{providerName}] Outputs and schedules checks passed.");
}
</Script>
