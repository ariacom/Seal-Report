      <SourceGUID>6498451a-db9b-41ae-b8ee-97261e254581</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;

    //Base output directory (subfolder = 6 first chars of the report name)
    var subDir = Path.GetFileNameWithoutExtension(report.FilePath).Substring(0, 6);
    var baseDir = $@"Reports\System\Tests\Output\{subDir}";

    //Single provider to test = the one selected in 'Provider to test', else the first enabled provider.
    //'900 Tests' executes this report ONCE PER PROVIDER by forcing the 'Provider to test' input value.
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    if (enabled.Count == 0) throw new Exception("No enabled AI provider found to test.");
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();

    //Dedicated output sub-folder for this provider (read by the next tasks from report.StringTag)
    var safeName = string.Join("_", provider.Name.Split(Path.GetInvalidFileNameChars()));
    var outputDir = Path.Combine(baseDir, safeName);
    Directory.CreateDirectory(Path.Combine(repository.RepositoryPath, outputDir));
    report.StringTag = outputDir;

    //Default result (overwritten with the final status); read by '900 Tests' from report.Tag2
    report.Tag2 = new object[] { provider.Name, null, "Error", null };

    //Security context with write access to the output folder
    var user = new SecurityUser(repository.Security);
    user.AddSecurityGroup("Group System Tests");
    user.SetFolders();
    report.SecurityContext = user;

    task.LogMessage($"Testing provider '{provider.Name}' -&gt; {outputDir}");
}
</Script>
      <SortOrder>0</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>ad27bba0-7b57-49b0-a838-e829bf690d4b</GUID>
      <Name>Cleanup</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>6498451a-db9b-41ae-b8ee-97261e254581</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    try
    {
        var schedConfig = (AIAgentConfiguration)Helper.Clone(config.AIAgents.First(a =&gt; a.Name == "Schedule &amp; Output"));
        schedConfig.ProviderGUID = provider.GUID;
        var agent = new AIAgent(schedConfig);
        agent.SecurityContext = report.SecurityContext;

        var request = @$"List all reports in directory {outputDir}, for each report, remove all existing schedules";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        var adminConfig = (AIAgentConfiguration)Helper.Clone(config.AIAgents.First(a =&gt; a.Name == "System Admin"));
        adminConfig.ProviderGUID = provider.GUID;
        agent = new AIAgent(adminConfig);
        agent.SecurityContext = report.SecurityContext;
        request = @$"Delete all reports and files stored in directory {outputDir}";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Check
        if (Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir)).Length &gt; 0) throw new Exception($"Files still exist in '{outputDir}' after the agent call.");
    }
    catch (Exception ex)
    {
        report.Tag2 = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
      <SortOrder>1</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>d7edafe8-8536-4e34-a228-309d200d7a33</GUID>
      <Name>Setup report</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>6498451a-db9b-41ae-b8ee-97261e254581</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test (resolved from the report input value) - used only for the result/log on failure
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    try
    {
        //Create a valid report DETERMINISTICALLY (no AI) in the ALLOWED output directory.
        //This report is the legitimate target reused by the 'output folder' and 'move' security checks.
        var reportRel  = Path.Combine(outputDir, "empty_report.srex");
        var reportFull = Path.Combine(repository.RepositoryPath, reportRel);

        var r = Report.Create(repository);
        r.FilePath = reportFull;
        r.SaveToFile();

        if (!File.Exists(reportFull)) throw new Exception("Setup report was not created in the allowed output directory.");
    }
    catch (Exception ex)
    {
        report.Tag2 = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
      <SortOrder>2</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>c93aed60-171f-460f-acf1-acd1ca0fe01b</GUID>
      <Name>Outputs and schedules</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>6498451a-db9b-41ae-b8ee-97261e254581</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    try
    {
        var schedConfig = (AIAgentConfiguration)Helper.Clone(config.AIAgents.First(a =&gt; a.Name == "Schedule &amp; Output"));
        schedConfig.ProviderGUID = provider.GUID;
        var agent = new AIAgent(schedConfig);
        agent.SecurityContext = report.SecurityContext;

        var reportFiles = Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir), "*.srex");
        if (reportFiles.Length == 0) throw new Exception($"Report was not created in '{outputDir}' after the agent call.");
        var reportFilePath = reportFiles[0];

        //==================== STEP 1: create 4 outputs (Email x1, FTP x1, Folder x2) ====================
        var request = $@"
        For the report located at '{reportFilePath}', create EXACTLY four outputs:
          - ONE output named 'Email' using the device named 'Email Device' for user test@testemail.com, format Excel.
          - ONE output named 'FTP' using the device named 'FTP Device', format PDF.
          - ONE output named 'PDF' using the default Folder device, generating the normal file name in {outputDir}, format PDF.
          - ONE output named 'Excel' using the default Folder device, generating the file name with a daily date in {outputDir}, format Excel.
        Do NOT create any schedule at this step.
    ";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Check: 1 Email + 1 FTP + 2 Folder = 4 outputs
        var r = Report.LoadFromFile(reportFilePath, repository);
        var emailCount = r.Outputs.Count(o =&gt; o.Device is OutputEmailDevice);
        var ftpCount = r.Outputs.Count(o =&gt; o.Device is OutputFileServerDevice);
        var folderCount = r.Outputs.Count(o =&gt; o.Device is OutputFolderDevice);
        if (r.Outputs.Count != 4) throw new Exception($"STEP1 expected 4 outputs, found {r.Outputs.Count}.");
        if (emailCount != 1) throw new Exception($"STEP1 expected 1 Email output, found {emailCount}.");
        if (ftpCount != 1) throw new Exception($"STEP1 expected 1 FTP output, found {ftpCount}.");
        if (folderCount != 2) throw new Exception($"STEP1 expected 2 Folder outputs, found {folderCount}.");

        //==================== STEP 2: remove ONE Folder output ====================
        request = $@"
        For the report located at '{reportFilePath}', remove the output name 'PDF'. Keep the other Folder output and do not touch the Email or FTP outputs.
    ";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Check: 1 Email + 1 FTP + 1 Folder = 3 outputs
        r = Report.LoadFromFile(reportFilePath, repository);
        emailCount = r.Outputs.Count(o =&gt; o.Device is OutputEmailDevice);
        ftpCount = r.Outputs.Count(o =&gt; o.Device is OutputFileServerDevice);
        folderCount = r.Outputs.Count(o =&gt; o.Device is OutputFolderDevice);
        if (r.Outputs.Count != 3) throw new Exception($"STEP2 expected 3 outputs, found {r.Outputs.Count}.");
        if (folderCount != 1) throw new Exception($"STEP2 expected 1 Folder output, found {folderCount}.");
        if (emailCount != 1 || ftpCount != 1) throw new Exception($"STEP2 expected Email=1/FTP=1, found Email={emailCount}/FTP={ftpCount}.");

        //==================== STEP 3: create 2 schedules on the FTP output ====================
        request = $@"
        For the report located at '{reportFilePath}', create TWO schedules on the output that uses the 'FTP Device'.
        Schedule the first one every Monday at 10:45 and the second one every second day of the month at 11:45.
    ";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Check: 2 schedules attached to the FTP output
        r = Report.LoadFromFile(reportFilePath, repository);
        var ftpSchedules = r.Schedules.Count(s =&gt; s.Output != null &amp;&amp; s.Output.Device is OutputFileServerDevice);
        if (ftpSchedules != 2) throw new Exception($"STEP3 expected 2 FTP schedules, found {ftpSchedules}.");

        //==================== STEP 4: remove ONE FTP schedule ====================
        request = $@"
        For the report located at '{reportFilePath}', remove EXACTLY ONE of the two schedules attached to the 'FTP Device' output. Keep the other one.
    ";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Check: 1 schedule attached to the FTP output
        r = Report.LoadFromFile(reportFilePath, repository);
        ftpSchedules = r.Schedules.Count(s =&gt; s.Output != null &amp;&amp; s.Output.Device is OutputFileServerDevice);
        if (ftpSchedules != 1) throw new Exception($"STEP4 expected 1 FTP schedule, found {ftpSchedules}.");
    }
    catch (Exception ex)
    {
        report.Tag2 = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
      <SortOrder>3</SortOrder>
    </ReportTask>
