      <SourceGUID>7c9d2e3a-1f4b-4a6c-9d8e-2b5a7c1f0e44</SourceGUID>
      <Script>@{
    ReportTask task = Model;
    Report report = task.Report;

    //All scenarios passed: record the success result read by '900 Tests' from report.Tag2
    var pr = report.Tag2 as object[];
    var providerName = pr != null ? (string)pr[0] : null;
    report.Tag2 = new object[] { providerName, null, "Success", null };
    task.LogMessage($"[{providerName}] All Data Analyst scenarios passed.");
}
</Script>
