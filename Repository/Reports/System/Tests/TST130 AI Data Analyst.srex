      <GUID>2c000000-0000-4000-9000-000000000006</GUID>
      <Name>Report discovery</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>7c9d2e3a-1f4b-4a6c-9d8e-2b5a7c1f0e44</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    var salesTime = Path.Combine(outputDir, "Sales per Year and Month.srex");

    try
    {
        var analystConfig = (AIAssistantConfiguration)Helper.Clone(config.AIAssistants.First(a =&gt; a.Name == "Data Analyst"));
        analystConfig.ProviderGUID = provider.GUID;

        //No path is given: the analyst must locate the report itself via report_list.
        var analyst = new AIAssistant(analystConfig);
        analyst.SecurityContext = report.SecurityContext;
        var question = "Find the report in my workspace that breaks down sales by year and month, then tell me which calendar year had the highest total sales. Locate the report yourself; do not ask me for its path.";
        if (chatLog != null) task.LogMessage("Q: " + question);
        var answer = analyst.Chat(question, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;
        if (chatLog != null) task.LogMessage("A: " + answer);

        var judge = new AIAssistant(analystConfig);
        judge.SecurityContext = report.SecurityContext;
        var judgePrompt = $@"You are independently verifying another analyst's answer.
Question asked: {question}
Answer given: {answer}
The report the analyst was expected to find is located at '{salesTime}'. Execute it, determine which calendar year had the highest total sales, and check the answer.
Reply with EXACTLY 'CHECK OK' (and nothing else) if the answer names the correct year. Otherwise reply with 'CHECK FAILED: ' followed by a short reason.";
        var verdict = judge.Chat(judgePrompt, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;
        task.LogMessage("Verdict: " + verdict);

        if (verdict == null || !verdict.ToString().Contains("CHECK OK"))
            throw new Exception($"Discovery scenario failed verification: {verdict}");
    }
    catch (Exception ex)
    {
        report.Tag2 = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
