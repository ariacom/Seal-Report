    <ReportTask>
      <GUID>2c000000-0000-4000-9000-000000000004</GUID>
      <Name>Setup data</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>7c9d2e3a-1f4b-4a6c-9d8e-2b5a7c1f0e44</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    try
    {
        //The Data Analyst is read-only, so the source reports are built deterministically by the Report Designer.
        var designerConfig = (AIAssistantConfiguration)Helper.Clone(config.AIAssistants.First(a =&gt; a.Name == "Report Designer"));
        designerConfig.ProviderGUID = provider.GUID;
        var designer = new AIAssistant(designerConfig);
        designer.SecurityContext = report.SecurityContext;

        var req1 = $@"Create a report named 'Sales per Year and Month.srex' in directory {outputDir} using the Northwind data source.
The model must contain:
  - a Row dimension 'Year' = the year of the order date (Orders.OrderDate),
  - a Row dimension 'Month' = the month number (1 to 12) of the order date (Orders.OrderDate),
  - a Data element 'Total Sales' = the SUM of the order line amount computed as (Order Details UnitPrice * Quantity * (1 - Discount)), joining Order Details to Orders.
Group by Year then Month and sort ascending. Each Year/Month combination must appear exactly once.";
        if (chatLog != null) task.LogMessage(req1);
        designer.Chat(req1, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        var req2 = $@"Create a report named 'Sales per Customer.srex' in directory {outputDir} using the Northwind data source.
The model must contain:
  - a Row dimension 'Customer' = Customers.CompanyName,
  - a Data element 'Total Sales' = the SUM of (Order Details UnitPrice * Quantity * (1 - Discount)), joining Order Details, Orders and Customers.
Sort the rows by Total Sales DESCENDING so the biggest customer appears first.";
        if (chatLog != null) task.LogMessage(req2);
        designer.Chat(req2, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        var req3 = $@"Create a report named 'Sales per Employee.srex' in directory {outputDir} using the Northwind data source.
The model must contain:
  - a Row dimension 'Employee' = the employee last name (Employees.LastName),
  - a Data element 'Total Sales' = the SUM of (Order Details UnitPrice * Quantity * (1 - Discount)), joining Order Details, Orders and Employees.
Sort the rows by Total Sales DESCENDING.";
        if (chatLog != null) task.LogMessage(req3);
        designer.Chat(req3, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Verify the three source reports were created.
        var dir = Path.Combine(repository.RepositoryPath, outputDir);
        var f1 = "Sales per Year and Month.srex";
        var f2 = "Sales per Customer.srex";
        var f3 = "Sales per Employee.srex";
        if (!File.Exists(Path.Combine(dir, f1)) || !File.Exists(Path.Combine(dir, f2)) || !File.Exists(Path.Combine(dir, f3)))
            throw new Exception("Setup failed: expected 3 sales reports in '" + outputDir + "'. Found: " + string.Join(", ", Directory.GetFiles(dir, "*.srex").Select(Path.GetFileName)) + ".");
    }
    catch (Exception ex)
    {
        report.Tag2 = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
      <SortOrder>2</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>2c000000-0000-4000-9000-000000000005</GUID>
      <Name>Business questions</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>7c9d2e3a-1f4b-4a6c-9d8e-2b5a7c1f0e44</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    var salesTime = Path.Combine(outputDir, "Sales per Year and Month.srex");
    var customers = Path.Combine(outputDir, "Sales per Customer.srex");
    var employees = Path.Combine(outputDir, "Sales per Employee.srex");

    try
    {
        var analystConfig = (AIAssistantConfiguration)Helper.Clone(config.AIAssistants.First(a =&gt; a.Name == "Data Analyst"));
        analystConfig.ProviderGUID = provider.GUID;

        //Each scenario: { name, report path, business question }. Answers are graded by an independent judge assistant.
        var scenarios = new List&lt;string[]&gt;
        {
            new[] { "Highest sales year", salesTime, "Using the report at '" + salesTime + "', which calendar year had the highest total sales? Name the year." },
            new[] { "Lowest sales year", salesTime, "Using the report at '" + salesTime + "', which calendar year had the lowest total sales, and what is a likely reason?" },
            new[] { "Sales growth", salesTime, "Using the report at '" + salesTime + "', did total sales grow or decline between the first two full calendar years available?" },
            new[] { "Strongest month", salesTime, "Using the report at '" + salesTime + "', which calendar month tends to be the strongest for sales across the years?" },
            new[] { "Top 3 customers", customers, "Using the report at '" + customers + "', who are the top 3 customers by total sales?" },
            new[] { "Top customer", customers, "Using the report at '" + customers + "', which single customer ranks first by total sales?" },
            new[] { "Top employee", employees, "Using the report at '" + employees + "', which employee generated the most sales?" },
            new[] { "Lowest employee", employees, "Using the report at '" + employees + "', which employee generated the least sales?" }
        };

        foreach (var s in scenarios)
        {
            if (report.Cancel) return;
            var name = s[0];
            var path = s[1];
            var question = s[2];
            task.LogMessage($"--- Scenario: {name} ---");

            //Analyst under test answers the business question.
            var analyst = new AIAssistant(analystConfig);
            analyst.SecurityContext = report.SecurityContext;
            if (chatLog != null) task.LogMessage("Q: " + question);
            var answer = analyst.Chat(question, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
            if (report.Cancel) return;
            if (chatLog != null) task.LogMessage("A: " + answer);

            //Independent judge re-executes the report and grades the answer against the real data.
            var judge = new AIAssistant(analystConfig);
            judge.SecurityContext = report.SecurityContext;
            var judgePrompt = $@"You are independently verifying another analyst's answer to a business question.
Question: {question}
Answer given by the analyst: {answer}
The relevant report is located at '{path}'. Independently execute that report, determine the correct answer from the actual data, and compare it with the answer given.
Reply with EXACTLY 'CHECK OK' (and nothing else) if the analyst's answer is factually correct and consistent with the data.
Otherwise reply with 'CHECK FAILED: ' followed by a short reason.";
            var verdict = judge.Chat(judgePrompt, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
            if (report.Cancel) return;
            task.LogMessage("Verdict: " + verdict);

            if (verdict == null || !verdict.ToString().Contains("CHECK OK"))
                throw new Exception($"Scenario '{name}' failed verification: {verdict}");
        }
    }
    catch (Exception ex)
    {
        report.Tag2 = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
      <SortOrder>3</SortOrder>
    </ReportTask>
