  <Tasks>
    <ReportTask>
      <GUID>c1a2b3d4-0220-4a00-9000-000000000001</GUID>
      <Name>Init</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>c1a2b3d4-0220-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;

    //Single provider to test = the one selected in 'Provider to test', else the first enabled provider.
    //'900 Tests' executes this report ONCE PER PROVIDER by forcing the 'Provider to test' input value.
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    if (enabled.Count == 0) throw new Exception("No enabled AI provider found to test.");
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();

    //Default result (overwritten with the final status); read by '900 Tests' from report.Tag2
    report.Tag2 = new object[] { provider.Name, null, "Error", null };

    //Read-only context with Execute right on the System reports (Group System Tests grants \System Execute).
    var user = new SecurityUser(repository.Security);
    user.AddSecurityGroup("Group System Tests");
    user.SetFolders();
    report.SecurityContext = user;

    task.LogMessage($"Testing the System Admin audit-security-and-activity skill with provider '{provider.Name}'.");
}
</Script>
      <SortOrder>0</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>c1a2b3d4-0220-4a00-9000-000000000002</GUID>
      <Name>Security audit question</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>c1a2b3d4-0220-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;
@using System.Text;
@using System.Globalization;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    try
    {
        //Ground truth: distinctive security group names that ARE defined in Security.xml.
        //The agent must run a System security/audit report (e.g. '100 Configuration - Security Summary')
        //to enumerate the groups - it cannot know these test group names without reading the configuration.
        var distinctiveGroups = new[] { "Group System Tests", "Group Data Analyst Tests", "Group (Demo)" };
        var present = distinctiveGroups.Where(g =&gt; repository.Security.Groups.Any(sg =&gt; sg.Name == g)).ToArray();
        if (present.Length &lt; 2) throw new Exception("Test pre-condition failed: fewer than 2 distinctive groups exist in Security.xml.");

        //The System Admin agent must load audit-security-and-activity and execute the security summary report.
        var adminConfig = (AIAgentConfiguration)Helper.Clone(config.AIAgents.First(a =&gt; a.Name == "System Admin"));
        adminConfig.ProviderGUID = provider.GUID;
        var agent = new AIAgent(adminConfig);
        agent.SecurityContext = report.SecurityContext;

        var request = @"Using the built-in security/audit reports of this Seal Report server, list the names of all the security GROUPS that are defined. Give me each group name exactly as configured.";
        if (chatLog != null) task.LogMessage(request);
        var answer = agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;
        if (chatLog != null &amp;&amp; answer != null) task.LogMessage("A: " + answer);

        //Deterministic check: the answer must name at least two distinctive groups it could only know
        //by actually running the security report (proves the audit-security-and-activity skill worked).
        var matched = present.Count(g =&gt; ContainsToken(answer, g));
        if (matched &lt; 2)
        {
            var got = answer == null ? "" : answer.ToString();
            if (got.Length &gt; 300) got = got.Substring(0, 300) + "...";
            throw new Exception($"Expected the agent to name at least 2 of [{string.Join(", ", present)}] from the security report, matched {matched}. Got: {got}");
        }

        task.LogMessage($"[{provider.Name}] Security audit returned {matched} expected group name(s).");
    }
    catch (Exception ex)
    {
        report.Tag2 = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}

@functions {
    //Case- and accent-insensitive 'contains the token' test (same approach as TST300).
    bool ContainsToken(object answer, string token)
    {
        if (answer == null || string.IsNullOrEmpty(token)) return false;
        return Normalize(answer.ToString()).Contains(Normalize(token));
    }

    string Normalize(string s)
    {
        if (string.IsNullOrEmpty(s)) return "";
        var formD = s.ToLowerInvariant().Normalize(NormalizationForm.FormD);
        var sb = new StringBuilder();
        foreach (var c in formD) {
            if (CharUnicodeInfo.GetUnicodeCategory(c) != UnicodeCategory.NonSpacingMark) sb.Append(c);
        }
        return sb.ToString().Normalize(NormalizationForm.FormC);
    }
}
</Script>
      <SortOrder>1</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>c1a2b3d4-0220-4a00-9000-000000000003</GUID>
      <Name>Result</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>c1a2b3d4-0220-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@{
    ReportTask task = Model;
    Report report = task.Report;

    //All checks passed: record the success result read by '900 Tests' from report.Tag2
    var pr = report.Tag2 as object[];
    var providerName = pr != null ? (string)pr[0] : null;
    report.Tag2 = new object[] { providerName, null, "Success", null };
    task.LogMessage($"[{providerName}] Audit-security-and-activity check passed.");
}
</Script>
      <SortOrder>2</SortOrder>
    </ReportTask>
