  <Tasks>
    <ReportTask>
      <GUID>c1a2b3d4-0140-4a00-9000-000000000001</GUID>
      <Name>Init</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>c1a2b3d4-0140-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;

    //Base output directory (subfolder = 6 first chars of the report name)
    var subDir = Path.GetFileNameWithoutExtension(report.FilePath).Substring(0, 6);
    var baseDir = $@"Reports\System\Tests\Output\{subDir}";

    //Single provider to test = the one selected in 'Provider to test', else the first enabled provider.
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    if (enabled.Count == 0) throw new Exception("No enabled AI provider found to test.");
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();

    //Dedicated output sub-folder for this provider (read by the next tasks from report.StringTag)
    var safeName = string.Join("_", provider.Name.Split(Path.GetInvalidFileNameChars()));
    var outputDir = Path.Combine(baseDir, safeName);
    Directory.CreateDirectory(Path.Combine(repository.RepositoryPath, outputDir));
    report.StringTag = outputDir;

    //Default result (overwritten with the final status); read by '900 Tests' from report.ResultTag
    report.ResultTag = new object[] { provider.Name, null, "Error", null };

    //Security context with Edit access to the output folder (\System\Tests)
    var user = new SecurityUser(repository.Security);
    user.AddSecurityGroup("Group System Tests");
    user.SetFolders();
    report.SecurityContext = user;

    task.LogMessage($"Testing the style-report-view skill with provider '{provider.Name}' -&gt; {outputDir}");
}
</Script>
      <SortOrder>0</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>c1a2b3d4-0140-4a00-9000-000000000002</GUID>
      <Name>Cleanup</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>c1a2b3d4-0140-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@using System.IO;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var outputDir = report.StringTag;

    try
    {
        task.LogMessage($"Executing '{task.Name}'");
        var dir = Path.Combine(repository.RepositoryPath, outputDir);
        if (Directory.Exists(dir))
            foreach (var f in Directory.GetFiles(dir)) File.Delete(f);
    }
    catch (Exception ex)
    {
        var pr = report.ResultTag as object[];
        var pn = pr != null ? (string)pr[0] : null;
        report.ResultTag = new object[] { pn, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
      <SortOrder>1</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>c1a2b3d4-0140-4a00-9000-000000000003</GUID>
      <Name>Setup chart report</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>c1a2b3d4-0140-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@using Seal.Model;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var outputDir = report.StringTag;

    try
    {
        task.LogMessage($"Executing '{task.Name}'");

        //Reuse the TST110 pattern report (a Northwind bar chart with a 'Chart JS' view) as the styling target.
        var source = Path.Combine(repository.RepositoryPath, "Reports", "System", "Tests", "Pattern", "TST110", "sales_by_country_and_product_category_in_1997.srex");
        if (!File.Exists(source)) throw new Exception($"Styling source report not found: '{source}'.");
        var targetFull = Path.Combine(repository.RepositoryPath, outputDir, "chart_report.srex");

        //Load, re-GUID, RESET the chart orientation to its default (so the agent's job - turn it horizontal - is verifiable), and save.
        var r = Report.LoadFromFile(source, repository);
        r.InitGUIDs();
        var chartView = FindView(r.Views, "Chart JS");
        if (chartView == null) throw new Exception("The styling source report has no 'Chart JS' view.");
        chartView.Parameters.RemoveAll(p =&gt; p.Name == "chartjs_bar_horizontal" || p.Name == "chartjs_bar_stacked");
        r.FilePath = targetFull;
        r.SaveToFile();

        //Sanity: the orientation must start NON-horizontal so the test can detect the agent's change.
        var check = Report.LoadFromFile(targetFull, repository);
        var cv = FindView(check.Views, "Chart JS");
        var initial = cv.GetValue("chartjs_bar_horizontal");
        if (initial == "True") throw new Exception("Setup precondition failed: the chart is already horizontal.");

        //Stash the report GUID so the action task can assert the report was restyled IN PLACE (GUID unchanged).
        report.Tag = check.GUID;
        task.LogMessage($"Styling target created (chartjs_bar_horizontal initial value: '{(string.IsNullOrEmpty(initial) ? "(default)" : initial)}').");
    }
    catch (Exception ex)
    {
        var pr = report.ResultTag as object[];
        var pn = pr != null ? (string)pr[0] : null;
        report.ResultTag = new object[] { pn, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}

@functions {
    //Recursively find a view by name in the report view tree.
    ReportView FindView(System.Collections.Generic.List&lt;ReportView&gt; views, string name)
    {
        if (views == null) return null;
        foreach (var v in views)
        {
            if (v.Name == name) return v;
            var found = FindView(v.Views, name);
            if (found != null) return found;
        }
        return null;
    }
}
</Script>
      <SortOrder>2</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>c1a2b3d4-0140-4a00-9000-000000000004</GUID>
      <Name>Style the chart</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>c1a2b3d4-0140-4061-8a9b-0c1d2e3f4a50</SourceGUID>
      <Script>@using Seal.AI;
@using Seal.Model;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    var targetRel = Path.Combine(outputDir, "chart_report.srex");
    var targetFull = Path.Combine(repository.RepositoryPath, targetRel);
    var expectedGuid = report.Tag as string;

    try
    {
        //The Report Designer agent must load the style-report-view skill and use
        //view_get_parameters + report_configure_view to turn the bar chart horizontal IN PLACE.
        var designerConfig = (AIAgentConfiguration)Helper.Clone(config.AIAgents.First(a =&gt; a.Name == "Report Designer"));
        designerConfig.ProviderGUID = provider.GUID;
        var agent = new AIAgent(designerConfig);
        agent.SecurityContext = report.SecurityContext;

        var request = $@"For the report located at '{targetRel}', restyle its 'Chart JS' view so the bar chart is displayed HORIZONTALLY (horizontal bars). Change only this view parameter; do not rewrite the report.";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Check: the Chart JS view is now horizontal, and the report was edited in place (same GUID, still loads).
        var r = Report.LoadFromFile(targetFull, repository);
        if (!string.IsNullOrEmpty(r.LoadErrors)) throw new Exception($"The restyled report no longer loads: {r.LoadErrors}");
        var chartView = FindView(r.Views, "Chart JS");
        if (chartView == null) throw new Exception("The 'Chart JS' view disappeared after styling.");
        var horizontal = chartView.GetValue("chartjs_bar_horizontal");
        if (horizontal != "True")
            throw new Exception($"Expected chartjs_bar_horizontal='True' on the 'Chart JS' view, found '{(string.IsNullOrEmpty(horizontal) ? "(default/not set)" : horizontal)}'.");
        if (!string.IsNullOrEmpty(expectedGuid) &amp;&amp; r.GUID != expectedGuid)
            throw new Exception($"The report was rewritten (GUID changed) instead of being restyled in place.");

        task.LogMessage($"[{provider.Name}] Chart JS view set to horizontal in place.");
    }
    catch (Exception ex)
    {
        report.ResultTag = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}

@functions {
    //Recursively find a view by name in the report view tree.
    ReportView FindView(System.Collections.Generic.List&lt;ReportView&gt; views, string name)
    {
        if (views == null) return null;
        foreach (var v in views)
        {
            if (v.Name == name) return v;
            var found = FindView(v.Views, name);
            if (found != null) return found;
        }
        return null;
    }
}
</Script>
      <SortOrder>3</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>c1a2b3d4-0140-4a00-9000-000000000006</GUID>
