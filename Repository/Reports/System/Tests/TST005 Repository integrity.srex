<?xml version="1.0"?>
<Report xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <GUID>b1a7c010-0005-4a00-9000-000000000001</GUID>
  <ViewGUID>b1a7c010-0005-4a00-9000-000000000501</ViewGUID>
  <Sources>
    <ReportSource>
      <GUID>b1a7c010-0005-4a00-9000-000000000101</GUID>
      <Name>Audit SQLite (Repository)</Name>
      <ConnectionGUID>1</ConnectionGUID>
      <MetaData />
      <MetaSourceGUID>3d80412e-03a4-4a96-818a-a2aecef4c813</MetaSourceGUID>
    </ReportSource>
  </Sources>
  <Models>
    <ReportModel>
      <GUID>b1a7c010-0005-4a00-9000-000000000301</GUID>
      <Name>Model</Name>
      <SourceGUID>b1a7c010-0005-4a00-9000-000000000101</SourceGUID>
    </ReportModel>
  </Models>
  <Tasks>
    <ReportTask>
      <GUID>b1a7c010-0005-4a00-9000-000000000401</GUID>
      <Name>Check Repository Integrity</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>b1a7c010-0005-4a00-9000-000000000101</SourceGUID>
      <Script>@using System;
@using System.IO;
@using System.Linq;
@using System.Collections.Generic;
@using Seal.Model;
@using Seal.AI;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var errors = new List&lt;string&gt;();
    int count = 0;

    CheckRepository(report, errors, ref count);

    report.LogMessage("Checked integrity of {0} shipped repository script(s).", count);
    if (errors.Count &gt; 0)
        throw new Exception($"Repository integrity errors ({errors.Count}):" + Environment.NewLine + string.Join(Environment.NewLine, errors));
    report.LogMessage("All {0} shipped repository script(s) compiled successfully.", count);
}

@functions {
    //Compiles every Razor script shipped in the repository tree, at both levels:
    //the outer .cshtml template (which configures the object) and the inner runtime
    //script(s) it produces. Errors are collected so a single run reports every failure.
    void CheckRepository(Report report, List&lt;string&gt; errors, ref int count)
    {
        var repository = report.Repository;

        //1. Task templates: outer .cshtml + inner Script / BodyScript (model: ReportTask)
        foreach (var t in ReportTaskTemplate.LoadTemplates(repository.TaskTemplatesFolder).OrderBy(i =&gt; i.Name))
        {
            if (report.Cancel) return;
            report.LogMessage("Checking task template '{0}'", t.Name);
            var script = t.DefaultScript;        //accessing Default* parses the outer template
            var bodyScript = t.DefaultBodyScript;
            count++;
            if (!string.IsNullOrEmpty(t.Error)) errors.Add($"[Task template '{t.Name}'] configuration error: {t.Error}");
            Comp(errors, $"Task template '{t.Name}' (Script)", script, typeof(ReportTask));
            Comp(errors, $"Task template '{t.Name}' (BodyScript)", bodyScript, typeof(ReportTask));
        }

        //2. Table templates: outer .cshtml + inner definition / load scripts (model: MetaTable)
        foreach (var t in MetaTableTemplate.LoadTemplates(repository.TableTemplatesFolder).OrderBy(i =&gt; i.Name))
        {
            if (report.Cancel) return;
            report.LogMessage("Checking table template '{0}'", t.Name);
            var initScript = t.DefaultDefinitionInitScript;
            var defScript = t.DefaultDefinitionScript;
            var loadScript = t.DefaultLoadScript;
            count++;
            if (!string.IsNullOrEmpty(t.Error)) errors.Add($"[Table template '{t.Name}'] configuration error: {t.Error}");
            Comp(errors, $"Table template '{t.Name}' (DefinitionInitScript)", initScript, typeof(MetaTable));
            Comp(errors, $"Table template '{t.Name}' (DefinitionScript)", defScript, typeof(MetaTable));
            Comp(errors, $"Table template '{t.Name}' (LoadScript)", loadScript, typeof(MetaTable));
        }

        //3. View templates: outer .config.cshtml + main / renderer body (model: Report)
        foreach (var t in ReportViewTemplate.LoadTemplates(repository.ViewsFolder))
        {
            if (report.Cancel) return;
            var label = string.IsNullOrEmpty(t.RendererType) ? t.Name : $"{t.Name} [{t.RendererType}]";
            report.LogMessage("Checking view template '{0}'", label);
            t.ParseConfiguration();
            count++;
            if (!string.IsNullOrEmpty(t.Error)) errors.Add($"[View template '{label}'] configuration error: {t.Error}");
            Comp(errors, $"View template '{label}' (body)", t.Text, typeof(Report));
        }

        //4. Security providers: outer .cshtml + login Script / TwoFAScript (model: SecurityUser)
        foreach (var p in SecurityProvider.LoadProviders(repository.SecurityProvidersFolder).OrderBy(i =&gt; i.Name))
        {
            if (report.Cancel) return;
            report.LogMessage("Checking security provider '{0}'", p.Name);
            count++;
            if (!string.IsNullOrEmpty(p.Error)) errors.Add($"[Security provider '{p.Name}'] configuration error: {p.Error}");
            Comp(errors, $"Security provider '{p.Name}' (Script)", p.Script, typeof(SecurityUser));
            Comp(errors, $"Security provider '{p.Name}' (TwoFAScript)", p.TwoFAScript, typeof(SecurityUser));
        }

        //5. AI tool scripts (model: AIToolConfiguration)
        if (Directory.Exists(repository.AIScriptsFolder))
        {
            foreach (var path in Directory.GetFiles(repository.AIScriptsFolder, "*.cshtml").OrderBy(i =&gt; i))
            {
                if (report.Cancel) return;
                var name = Path.GetFileName(path);
                report.LogMessage("Checking AI tool script '{0}'", name);
                count++;
                Comp(errors, $"AI tool script '{name}'", File.ReadAllText(path), typeof(AIToolConfiguration));
            }
        }

        //6. Configuration scripts (empty by default - only compiled when set)
        var config = repository.Configuration;
        Comp(errors, "Configuration InitScript", config.InitScript, typeof(Report));
        Comp(errors, "Configuration ReportCreationScript", config.ReportCreationScript, typeof(Report));
        Comp(errors, "Configuration AuditScript", config.AuditScript, typeof(Audit));
        Comp(errors, "Configuration RepositoryTranslationsScript", config.RepositoryTranslationsScript, typeof(Repository));
    }

    //Compile a single shipped script; collect a readable error instead of stopping at the first failure.
    void Comp(List&lt;string&gt; errors, string label, string script, Type modelType)
    {
        if (string.IsNullOrWhiteSpace(script)) return;
        try
        {
            RazorHelper.Compile(RazorHelper.GetFullScript(script), modelType, Guid.NewGuid().ToString());
        }
        catch (RazorEngine.Templating.TemplateCompilationException ex)
        {
            errors.Add($"[{label}] does not compile: {Helper.GetExceptionMessage(ex)}");
        }
        catch (Exception ex)
        {
            errors.Add($"[{label}] error: {ex.Message}");
        }
    }
}
</Script>
      <SortOrder>1</SortOrder>
    </ReportTask>
  </Tasks>
  <Views>
    <ReportView>
      <GUID>b1a7c010-0005-4a00-9000-000000000501</GUID>
      <Name>View</Name>
      <Views>
        <ReportView>
          <GUID>b1a7c010-0005-4a00-9000-000000000502</GUID>
          <Name>Model</Name>
          <Views>
            <ReportView>
              <GUID>b1a7c010-0005-4a00-9000-000000000503</GUID>
              <Name>Container</Name>
              <Views>
                <ReportView>
                  <GUID>b1a7c010-0005-4a00-9000-000000000504</GUID>
                  <Name>Page Table</Name>
                  <TemplateName>Page Table</TemplateName>
                  <SortOrder>1</SortOrder>
                </ReportView>
                <ReportView>
                  <GUID>b1a7c010-0005-4a00-9000-000000000505</GUID>
                  <Name>Data Table</Name>
                  <TemplateName>Data Table</TemplateName>
                  <SortOrder>2</SortOrder>
                </ReportView>
              </Views>
              <TemplateName>Container</TemplateName>
              <SortOrder>1</SortOrder>
            </ReportView>
          </Views>
          <TemplateName>Model</TemplateName>
          <ModelGUID>b1a7c010-0005-4a00-9000-000000000301</ModelGUID>
          <SortOrder>1</SortOrder>
        </ReportView>
      </Views>
      <TemplateName>Report</TemplateName>
      <Parameters>
        <Parameter>
          <Name>messages_mode</Name>
          <Value>enabledshown</Value>
        </Parameter>
      </Parameters>
      <SortOrder>1</SortOrder>
    </ReportView>
  </Views>
  <Cancel>false</Cancel>
</Report>
