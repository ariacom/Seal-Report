      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>a116fbc2-ca0a-4e6a-b6d4-8c393bb79a42</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;

    //Base output directory (subfolder = 6 first chars of the report name)
    var subDir = Path.GetFileNameWithoutExtension(report.FilePath).Substring(0, 6);
    var baseDir = $@"Reports\System\Tests\Output\{subDir}";

    //Single provider to test = the one selected in 'Provider to test', else the first enabled provider.
    //'900 Tests' executes this report ONCE PER PROVIDER by forcing the 'Provider to test' input value.
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    if (enabled.Count == 0) throw new Exception("No enabled AI provider found to test.");
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();

    //Dedicated output sub-folder for this provider (read by the next tasks from report.StringTag)
    var safeName = string.Join("_", provider.Name.Split(Path.GetInvalidFileNameChars()));
    var outputDir = Path.Combine(baseDir, safeName);
    Directory.CreateDirectory(Path.Combine(repository.RepositoryPath, outputDir));
    report.StringTag = outputDir;

    //Default result (overwritten with the final status); read by '900 Tests' from report.Tag2
    report.Tag2 = new object[] { provider.Name, null, "Error", null };

    //Security context with write access to the output folder
    var user = new SecurityUser(repository.Security);
    user.AddSecurityGroup("Group System Tests");
    user.SetFolders();
    report.SecurityContext = user;

    task.LogMessage($"Testing provider '{provider.Name}' -&gt; {outputDir}");
}
</Script>
      <SortOrder>0</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>f1102e88-89ac-46a2-8761-15af8bbd6f2f</GUID>
      <Name>Cleanup</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>a116fbc2-ca0a-4e6a-b6d4-8c393bb79a42</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    try
    {
        var schedConfig = (AIAgentConfiguration)Helper.Clone(config.AIAgents.First(a =&gt; a.Name == "Schedule &amp; Output"));
        schedConfig.ProviderGUID = provider.GUID;
        var agent = new AIAgent(schedConfig);
        agent.SecurityContext = report.SecurityContext;

        var request = @$"List all reports in directory {outputDir}, for each report, remove all existing schedules";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        var adminConfig = (AIAgentConfiguration)Helper.Clone(config.AIAgents.First(a =&gt; a.Name == "System Admin"));
        adminConfig.ProviderGUID = provider.GUID;
        agent = new AIAgent(adminConfig);
        agent.SecurityContext = report.SecurityContext;
        request = @$"Delete all reports and files stored in directory {outputDir}";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Check
        if (Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir)).Length &gt; 0) throw new Exception($"Files still exist in '{outputDir}' after the agent call.");
    }
    catch (Exception ex)
    {
        report.Tag2 = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
      <SortOrder>1</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>38378b59-02a6-443a-a339-5200d8c444ee</GUID>
      <Name>Create report</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>a116fbc2-ca0a-4e6a-b6d4-8c393bb79a42</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    try
    {
        var designerConfig = (AIAgentConfiguration)Helper.Clone(config.AIAgents.First(a =&gt; a.Name == "Report Designer"));
        designerConfig.ProviderGUID = provider.GUID;
        var agent = new AIAgent(designerConfig);
        agent.SecurityContext = report.SecurityContext;

        var request = $@"
        Create a report named 'Top 10 best customers in 1997 in amount.srex' in directory {outputDir} using the Northwind data source.
        The report model must contain EXACTLY two elements:
          - 'Customer' (Customers.CompanyName) as the only Row dimension.
          - 'Amount' as a Data element aggregated with Sum, with a DESCENDING sort order so rows go from the highest total to the lowest.
        Restrict the data to the whole year 1997 by filtering Order Date between 1997-01-01 and 1997-12-31. The date is a RESTRICTION ONLY and must never be added as an element, row, column or grouping dimension.
        Group only by Customer so each customer appears once with its full-year total. Order the rows by total Amount descending and keep only the top 10, i.e. the 10 customers with the HIGHEST total amount (QUICK-Stop must be the first row, around 61,110).
        Do not add Order Date, Order Year, Order Month or any other column to the model.
    ";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Check report created and get its file path
        var reportFiles = Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir), "*.srex");
        if (reportFiles.Length == 0) throw new Exception($"Report was not created in '{outputDir}' after the agent call.");
        var reportFilePath = reportFiles[0];

        request = $@"
        Get the data of the report located at '{reportFilePath}'.
        Compare amounts rounded to the nearest whole number, ignoring decimals and thousand separators.
        Check that the first row in the table is the customer 'QUICK-Stop' with an amount that rounds to 61,110 (accept 61,109 to 61,111)
        and that the last customer is 'Folk och fä HB' with an amount that rounds to 13,315 (accept 13,314 to 13,316).
        If both checks succeed, answer with exactly 'CHECK OK'.
        If any check fails, answer with exactly 'CHECK FAILED' followed by the reason.
    ";
        if (chatLog != null) task.LogMessage(request);
        var checkResult = agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        if (checkResult == null || !checkResult.ToString().Contains("CHECK OK"))
            throw new Exception($"Data check failed for '{reportFilePath}': {checkResult}");
    }
    catch (Exception ex)
    {
        report.Tag2 = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
      <SortOrder>2</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>31687d2e-b13c-4cc3-8fe8-12d7c1c700b1</GUID>
      <Name>Output and schedule</Name>
      <Tasks />
      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Default</TemplateName>
      <SourceGUID>a116fbc2-ca0a-4e6a-b6d4-8c393bb79a42</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;
@using System.Linq;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var outputDir = report.StringTag;

    //Provider under test and log level, resolved from the report input values
    var enabled = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    var providerSel = report.GetInputValueByName("Provider to test");
    var provider = (providerSel != null &amp;&amp; providerSel.EnumValues.Count &gt; 0)
        ? enabled.FirstOrDefault(p =&gt; p.GUID == providerSel.EnumValues[0]) ?? enabled.First()
        : enabled.First();
    var logSel = report.GetInputValueByName("Log level");
    var logLevel = (logSel != null &amp;&amp; !string.IsNullOrEmpty(logSel.FirstStringValue)) ? logSel.FirstStringValue : "ChatAndTools";
    ReportExecutionLog chatLog = (logLevel == "Minimum") ? null : report;
    ReportExecutionLog toolsLog = (logLevel == "ChatAndTools") ? report : null;

    task.LogMessage($"[{provider.Name}] Executing '{task.Name}'");

    try
    {
        var schedConfig = (AIAgentConfiguration)Helper.Clone(config.AIAgents.First(a =&gt; a.Name == "Schedule &amp; Output"));
        schedConfig.ProviderGUID = provider.GUID;
        var agent = new AIAgent(schedConfig);
        agent.SecurityContext = report.SecurityContext;

        var reportFiles = Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir), "*.srex");
        if (reportFiles.Length == 0) throw new Exception($"Report was not created in '{outputDir}' after the agent call.");
        var reportFilePath = reportFiles[0];

        var request = $@"
        Add an output folder in PDF to generate the report {reportFilePath}.
        Generate the file with a daily date in {outputDir}.
    ";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        request = $@"
        Schedule it every monday at 10:45.
    ";
        if (chatLog != null) task.LogMessage(request);
        agent.Chat(request, cancelOperation: report, log: chatLog, toolsLog: toolsLog);
        if (report.Cancel) return;

        //Check
        var outputReport = Report.LoadFromFile(reportFilePath, repository);
        if (outputReport.Outputs.Count != 1) throw new Exception($"No output was created after the agent call.");
        if (outputReport.Outputs.First().Format != ReportFormat.PDF) throw new Exception($"No PDF output was created after the agent call.");
        if (outputReport.Schedules.Count != 1) throw new Exception($"No schedule was created after the agent call.");
    }
    catch (Exception ex)
    {
        report.Tag2 = new object[] { provider.Name, null, "Error", $"[{task.Name}] {ex.Message}" };
        throw;
    }
}
</Script>
      <SortOrder>3</SortOrder>
    </ReportTask>
