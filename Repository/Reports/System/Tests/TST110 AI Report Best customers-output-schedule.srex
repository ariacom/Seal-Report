      <ExecProcessChildren>true</ExecProcessChildren>
      <TemplateName>Loop</TemplateName>
      <Parameters>
        <Parameter>
          <Name>thread</Name>
          <Value>0</Value>
        </Parameter>
      </Parameters>
      <SourceGUID>a116fbc2-ca0a-4e6a-b6d4-8c393bb79a42</SourceGUID>
      <BodyScript />
      <Script>@using Seal.AI;
@using System.IO;
@using System.Threading;
@using System.Threading.Tasks;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var config = Repository.Instance.AIConfiguration;
    var baseDir = report.StringTag;

    //Providers under test = every ENABLED AI provider defined in the AI Configuration
    var providers = config.AIProviders.Where(p =&gt; p.IsEnabled).ToList();
    if (providers.Count == 0) throw new Exception("No enabled AI provider found to test.");

    //Source assistant configurations (cloned per provider so nothing global is ever mutated)
    var sourceAssistants = config.AIAssistants.Where(a =&gt; a.IsEnabled).ToList();

    //Build one fully self-contained context per provider:
    //  - its own output sub-folder
    //  - its own cloned assistant configurations (forced to this provider)
    //  - its own cloned set of test tasks (cloned here, single threaded)
    var items = new List&lt;object&gt;();
    foreach (var provider in providers)
    {
        var safeName = string.Join("_", provider.Name.Split(Path.GetInvalidFileNameChars()));
        var providerDir = Path.Combine(baseDir, safeName);
        Directory.CreateDirectory(Path.Combine(repository.RepositoryPath, providerDir));

        var assistants = new Dictionary&lt;string, AIAssistantConfiguration&gt;();
        foreach (var a in sourceAssistants)
        {
            var clone = (AIAssistantConfiguration)Helper.Clone(a);
            clone.ProviderGUID = provider.GUID;
            assistants[a.Name] = clone;
        }

        var ctx = new Dictionary&lt;string, object&gt;();
        ctx["ProviderName"] = provider.Name;
        ctx["Provider"] = provider;
        ctx["OutputDir"] = providerDir;
        ctx["Assistants"] = assistants;

        var childTasks = new List&lt;ReportTask&gt;();
        foreach (var child in task.Tasks.Where(i =&gt; i.Enabled).OrderBy(i =&gt; i.SortOrder))
        {
            child.InitParameters();
            var newTask = (ReportTask)Helper.Clone(child);
            newTask.Report = report;
            newTask.InitReferences();
            newTask.IgnoreError = true;
            newTask.ExecInput = ctx;
            childTasks.Add(newTask);
        }
        ctx["Tasks"] = childTasks;
        items.Add(ctx);
    }

    //All provider sub-folders now exist: grant the shared security context write access ONCE
    report.SecurityContext.SetFolders();

    //Number of parallel threads (Loop 'thread' parameter; 0 = one thread per provider)
    var thread = task.GetNumericValue("thread");
    if (thread &lt;= 0 || thread &gt; items.Count) thread = items.Count;
    task.LogMessage($"Testing {items.Count} provider(s) using {thread} thread(s).");

    var queue = new List&lt;object&gt;(items);
    var results = new List&lt;string&gt;();
    var sync = new object();

    var workers = new List&lt;Task&gt;();
    for (int i = 0; i &lt; thread; i++)
    {
        workers.Add(Task.Run(() =&gt; RunProvider(queue, results, sync)));
        Thread.Sleep(50);
    }
    while (workers.Exists(w =&gt; !w.IsCompleted)) Thread.Sleep(100);

    report.StringTag = baseDir;

    var failures = results.Count(r =&gt; r.StartsWith("FAIL"));
    var summary = $"Provider test summary ({results.Count - failures}/{results.Count} passed):" + Environment.NewLine + string.Join(Environment.NewLine, results.OrderBy(r =&gt; r));
    task.LogMessage(summary);

    //Fail the report only AFTER every provider has been tested
    if (failures &gt; 0) throw new Exception(summary);
}

@functions {
    void RunProvider(List&lt;object&gt; queue, List&lt;string&gt; results, object sync)
    {
        ReportTask task = Model;
        Report report = task.Report;
        while (true)
        {
            Dictionary&lt;string, object&gt; ctx = null;
            lock (sync)
            {
                ctx = queue.FirstOrDefault() as Dictionary&lt;string, object&gt;;
                if (ctx != null) queue.Remove(ctx);
            }
            if (ctx == null || report.Cancel) break;

            var providerName = (string)ctx["ProviderName"];
            task.LogMessage($"==================== START provider '{providerName}' -&gt; {ctx["OutputDir"]} ====================");

            try
            {
                foreach (var child in (List&lt;ReportTask&gt;)ctx["Tasks"])
                {
                    if (report.Cancel) break;
                    child.Execute();
                    if (ctx.ContainsKey("Error")) break;
                }
            }
            catch (Exception ex)
            {
                ctx["Error"] = ex.Message;
            }

            string line;
            lock (sync)
            {
                if (ctx.ContainsKey("Error")) line = $"FAIL [{providerName}]: {ctx["Error"]}";
                else line = $"PASS [{providerName}]";
                results.Add(line);
            }
            task.LogMessage($"==================== END provider '{providerName}': {line} ====================");
        }
    }
}
</Script>
      <SortOrder>1</SortOrder>
    </ReportTask>
