          <Script>@using Seal.AI;
@using System.IO;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;
    var ctx = (Dictionary&lt;string, object&gt;)task.ExecInput;
    if (ctx.ContainsKey("Error")) return;
    var outputDir = (string)ctx["OutputDir"];
    var providerName = (string)ctx["ProviderName"];
    var assistants = (Dictionary&lt;string, AIAssistantConfiguration&gt;)ctx["Assistants"];

    try
    {
        task.LogMessage($"[{providerName}] Executing '{task.Name}'");

        var assistant = new AIAssistant(assistants["Schedule &amp; Output"]);
        assistant.SecurityContext = report.SecurityContext;

        var request = @$"List all reports in directory {outputDir}, for each report, remove all existing schedules";
        task.LogMessage(request);
        assistant.Chat(request, cancelOperation: report, log: report, toolsLog: report);
        if (report.Cancel) return;

        assistant = new AIAssistant(assistants["System Admin"]);
        assistant.SecurityContext = report.SecurityContext;
        request = @$"Delete all reports and files stored in directory {outputDir}";
        task.LogMessage(request);
        assistant.Chat(request, cancelOperation: report, log: report, toolsLog: report);
        if (report.Cancel) return;

        //Check
        if (Directory.GetFiles(Path.Combine(repository.RepositoryPath, outputDir)).Length &gt; 0) throw new Exception($"Files still exist in '{outputDir}' after the assistant call.");
    }
    catch (Exception ex) { ctx["Error"] = $"[{task.Name}] {ex.Message}"; }
}
</Script>
