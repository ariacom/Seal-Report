      <TemplateName>Default</TemplateName>
      <SourceGUID>0b32b277-d29a-4a24-9f94-f7e677d74082</SourceGUID>
      <Script>@using Seal.AI;
@using System.IO;

@{
    ReportTask task = Model;
    Report report = task.Report;
    var repository = report.Repository;

    //Single place defining the BASE output directory (subfolder = 6 first chars of the report name)
    var subDir = Path.GetFileNameWithoutExtension(report.FilePath).Substring(0, 6);
    report.StringTag = $@"Reports\System\Tests\Output\{subDir}";

    //Ensure the base output directory physically exists BEFORE building the security folders.
    Directory.CreateDirectory(Path.Combine(repository.RepositoryPath, report.StringTag));

    var user = new SecurityUser(repository.Security);
    user.AddSecurityGroup("Group System Tests");
    user.SetFolders();
    report.SecurityContext = user;
}
</Script>
      <SortOrder>0</SortOrder>
    </ReportTask>
    <ReportTask>
      <GUID>f9b2e525-177a-4a32-9b6b-258f145a7228</GUID>
